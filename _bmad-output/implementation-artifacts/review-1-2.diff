@@ -0,0 +1,206 @@
+"use client";
+
+import { useMemo, useState } from "react";
+import styles from "./status-diagnostic-form.module.css";
+import type {
+  GoalClarity,
+  LiquidityNeed,
+  ProductClarity,
+  TimePressure,
+} from "@/shared/contracts/intent-diagnostic";
+
+type FormState = {
+  goalClarity: GoalClarity;
+  productClarity: ProductClarity;
+  timePressure: TimePressure;
+  liquidityNeed: LiquidityNeed;
+};
+
+type ApiPayload = {
+  data: {
+    diagnostic: {
+      intent_maturity: string;
+      goal_confidence: string;
+      next_step: string;
+      reversibility_hint: string;
+      occurredAt: string;
+    };
+  };
+  meta: {
+    event: {
+      alias: string;
+      canonical: string;
+    };
+  };
+};
+
+const DEFAULT_FORM: FormState = {
+  goalClarity: "medium",
+  productClarity: "medium",
+  timePressure: "medium",
+  liquidityNeed: "medium",
+};
+
+const OPTIONS: { value: "low" | "medium" | "high"; label: string }[] = [
+  { value: "low", label: "낮음" },
+  { value: "medium", label: "보통" },
+  { value: "high", label: "높음" },
+];
+
+export function StatusDiagnosticForm() {
+  const [form, setForm] = useState<FormState>(DEFAULT_FORM);
+  const [isSubmitting, setIsSubmitting] = useState(false);
+  const [statusText, setStatusText] = useState("아직 진단 전");
+  const [nextStep, setNextStep] = useState("질문에 답하면 즉시 제안됩니다.");
+  const [reversibilityHint, setReversibilityHint] =
+    useState("언제든 입력값을 바꿔도 됩니다.");
+  const [eventAlias, setEventAlias] = useState("state_assessed");
+  const [eventCanonical, setEventCanonical] = useState("view_landing");
+
+  const summary = useMemo(
+    () => [
+      { label: "현재 상태", value: statusText },
+      { label: "다음 행동", value: nextStep },
+      { label: "가역성", value: reversibilityHint },
+    ],
+    [statusText, nextStep, reversibilityHint],
+  );
+
+  function updateField<K extends keyof FormState>(field: K, value: FormState[K]) {
+    setForm((prev) => ({ ...prev, [field]: value }));
+  }
+
+  async function handleSubmit(event: React.FormEvent<HTMLFormElement>) {
+    event.preventDefault();
+    setIsSubmitting(true);
+    setStatusText("저장 중");
+
+    const response = await fetch("/api/intents", {
+      method: "POST",
+      headers: {
+        "content-type": "application/json",
+        "x-idempotency-key": "landing-diagnostic-v1",
+      },
+      body: JSON.stringify({
+        input: form,
+        uiEventAlias: "state_assessed",
+      }),
+    });
+
+    if (!response.ok) {
+      setStatusText("저장 실패");
+      setNextStep("다음 행동: 입력값을 확인한 후 다시 시도하세요.");
+      setReversibilityHint("오류가 나도 현재 입력은 언제든 수정 가능합니다.");
+      setIsSubmitting(false);
+      return;
+    }
+
+    const payload = (await response.json()) as ApiPayload;
+    setStatusText("저장 완료");
+    setNextStep(`다음 행동: ${payload.data.diagnostic.next_step}`);
+    setReversibilityHint(payload.data.diagnostic.reversibility_hint);
+    setEventAlias(payload.meta.event.alias);
+    setEventCanonical(payload.meta.event.canonical);
+    setIsSubmitting(false);
+  }
+
+  return (
+    <section className={styles.container} aria-label="상태 진단 섹션">
+      <div className={styles.summaryGrid}>
+        {summary.map((item) => (
+          <article
+            key={item.label}
+            className={styles.summaryCard}
+            aria-label={`${item.label} 요약`}
+          >
+            <p className={styles.summaryTitle}>[i] {item.label}</p>
+            <p className={styles.summaryValue}>{item.value}</p>
+          </article>
+        ))}
+      </div>
+
+      <form className={styles.form} onSubmit={handleSubmit}>
+        <h2>현재 상태 진단</h2>
+
+        <QuestionField
+          legend="목표 명확도"
+          fieldName="goalClarity"
+          selected={form.goalClarity}
+          onSelect={(value) => updateField("goalClarity", value)}
+        />
+        <QuestionField
+          legend="상품 이해도"
+          fieldName="productClarity"
+          selected={form.productClarity}
+          onSelect={(value) => updateField("productClarity", value)}
+        />
+        <QuestionField
+          legend="시간 압박"
+          fieldName="timePressure"
+          selected={form.timePressure}
+          onSelect={(value) => updateField("timePressure", value)}
+        />
+        <QuestionField
+          legend="유동성 필요"
+          fieldName="liquidityNeed"
+          selected={form.liquidityNeed}
+          onSelect={(value) => updateField("liquidityNeed", value)}
+        />
+
+        <p className={styles.hint}>[!] 색상 대신 텍스트와 상태 라벨을 함께 제공합니다.</p>
+
+        <button
+          className={styles.submitButton}
+          type="submit"
+          disabled={isSubmitting}
+          aria-label="진단 저장 및 다음 행동 보기"
+        >
+          {isSubmitting ? "저장 중..." : "진단 저장 및 다음 행동 보기"}
+        </button>
+      </form>
+
+      <div className={styles.statusBox} role="status" aria-live="polite">
+        <p className={styles.statusText}>{statusText}</p>
+        <p>{nextStep}</p>
+        <p>{reversibilityHint}</p>
+        <p className={styles.eventText}>UI alias: {eventAlias}</p>
+        <p className={styles.eventText}>저장 canonical: {eventCanonical}</p>
+      </div>
+    </section>
+  );
+}
+
+type QuestionFieldProps = {
+  legend: string;
+  fieldName: keyof FormState;
+  selected: "low" | "medium" | "high";
+  onSelect: (value: "low" | "medium" | "high") => void;
+};
+
+function QuestionField({ legend, fieldName, selected, onSelect }: QuestionFieldProps) {
+  return (
+    <fieldset className={styles.fieldset}>
+      <legend className={styles.legend}>{legend}</legend>
+      <div className={styles.optionRow}>
+        {OPTIONS.map((option) => {
+          const inputId = `${fieldName}-${option.value}`;
+          return (
+            <label key={inputId} htmlFor={inputId} className={styles.optionLabel}>
+              <input
+                id={inputId}
+                type="radio"
+                name={fieldName}
+                value={option.value}
+                checked={selected === option.value}
+                onChange={() => onSelect(option.value)}
+                aria-label={`${legend} ${option.label}`}
+              />
+              <span className={styles.optionText}>{option.label}</span>
+            </label>
+          );
+        })}
+      </div>
+    </fieldset>
+  );
+}
+

+export const GOAL_CLARITY_VALUES = ["low", "medium", "high"] as const;
+export const PRODUCT_CLARITY_VALUES = ["low", "medium", "high"] as const;
+export const TIME_PRESSURE_VALUES = ["low", "medium", "high"] as const;
+export const LIQUIDITY_NEED_VALUES = ["low", "medium", "high"] as const;
+
+export type GoalClarity = (typeof GOAL_CLARITY_VALUES)[number];
+export type ProductClarity = (typeof PRODUCT_CLARITY_VALUES)[number];
+export type TimePressure = (typeof TIME_PRESSURE_VALUES)[number];
+export type LiquidityNeed = (typeof LIQUIDITY_NEED_VALUES)[number];
+
+export type IntentMaturity = "explore" | "refine" | "prepare";
+export type GoalConfidence = "low" | "medium" | "high";
+
+export type IntentDiagnosticInputDto = {
+  goalClarity: GoalClarity;
+  productClarity: ProductClarity;
+  timePressure: TimePressure;
+  liquidityNeed: LiquidityNeed;
+};
+
+export type IntentDiagnosticResultDto = {
+  intent_maturity: IntentMaturity;
+  goal_confidence: GoalConfidence;
+  next_step: string;
+  reversibility_hint: string;
+  occurredAt: string;
+};
+
+export type IntentDiagnosticEventAlias = "state_assessed";
+export type IntentDiagnosticEventCanonical = "view_landing";
+
+export type IntentDiagnosticRequestDto = {
+  input: IntentDiagnosticInputDto;
+  uiEventAlias: IntentDiagnosticEventAlias;
+};
+
+export const EVENT_ALIAS_TO_CANONICAL: Record<
+  IntentDiagnosticEventAlias,
+  IntentDiagnosticEventCanonical
+> = {
+  state_assessed: "view_landing",
+};

diff --git a/scripts/bmad-auto.ps1 b/scripts/bmad-auto.ps1
new file mode 100644
index 0000000..f02bc34
--- /dev/null
+++ b/scripts/bmad-auto.ps1
@@ -0,0 +1,90 @@
+[CmdletBinding(DefaultParameterSetName='step')]
+param(
+  [Parameter(Mandatory = $true)]
+  [string]$Slug,
+
+  [Parameter(ParameterSetName='init')]
+  [switch]$Init,
+
+  [Parameter(ParameterSetName='step')]
+  [ValidateSet('step-02','step-03','step-04','step-05','plan','implement','review','present')]
+  [string]$Step,
+
+  [Parameter(ParameterSetName='step')]
+  [switch]$FromSpec,
+
+  [string]$Tag = 'auto',
+  [switch]$CreateBaselineCommit,
+  [switch]$DryRun
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail([string]$Message) {
+  Write-Output "ERROR: $Message"
+  exit 1
+}
+
+function Resolve-StepAlias([string]$Value) {
+  switch ($Value) {
+    'plan' { return 'step-02' }
+    'implement' { return 'step-03' }
+    'review' { return 'step-04' }
+    'present' { return 'step-05' }
+    default { return $Value }
+  }
+}
+
+function Resolve-StepFromSpec([string]$SlugValue) {
+  $specPath = Join-Path $PSScriptRoot "../../_bmad-output/implementation-artifacts/spec-$SlugValue.md"
+  if (-not (Test-Path $specPath)) {
+    Fail "Spec file not found for slug: $SlugValue ($specPath)"
+  }
+
+  $content = Get-Content -Path $specPath
+  $statusLine = $content | Where-Object { $_ -match "^status:\s*'([^']+)'" } | Select-Object -First 1
+  if (-not $statusLine) {
+    Fail "Could not read spec status from: $specPath"
+  }
+
+  $null = ($statusLine -match "^status:\s*'([^']+)'")
+  $status = $Matches[1]
+
+  switch ($status) {
+    'ready-for-dev' { return 'step-02' }
+    'in-progress' { return 'step-03' }
+    'in-review' { return 'step-04' }
+    'done' { return 'step-05' }
+    default { Fail "Unsupported spec status for auto-step: $status" }
+  }
+}
+
+$gitScript = Join-Path $PSScriptRoot 'bmad-git.ps1'
+if (-not (Test-Path $gitScript)) {
+  Fail "Missing dependency: $gitScript"
+}
+
+if ($Init) {
+  $args = @('init', '-Slug', $Slug, '-RepositoryPath', '.')
+  if ($CreateBaselineCommit) { $args += '-CreateBaselineCommit' }
+  if ($DryRun) { $args += '-DryRun' }
+
+  & powershell -ExecutionPolicy Bypass -File $gitScript @args
+  exit $LASTEXITCODE
+}
+
+$resolvedStep = $null
+if ($FromSpec) {
+  $resolvedStep = Resolve-StepFromSpec -SlugValue $Slug
+} elseif ($Step) {
+  $resolvedStep = Resolve-StepAlias -Value $Step
+} else {
+  Fail 'Use -Step or -FromSpec for step mode.'
+}
+
+$commitArgs = @('commit', '-Slug', $Slug, '-Phase', $resolvedStep, '-Tag', $Tag, '-RepositoryPath', '.')
+if ($DryRun) { $commitArgs += '-DryRun' }
+
+& powershell -ExecutionPolicy Bypass -File $gitScript @commitArgs
+exit $LASTEXITCODE

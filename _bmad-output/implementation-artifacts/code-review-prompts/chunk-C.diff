+import { expect, test } from "@playwright/test";
+
+test.describe("핵심 사용자 여정", () => {
+  test("진입 페이지에서 상태 진단 후 다음 행동을 확인한다", async ({ page }) => {
+    await page.goto("/");
+
+    await expect(page.getByRole("heading", { name: "현재 상태 진단" })).toBeVisible();
+    await expect(page.getByLabel("현재 상태 요약")).toBeVisible();
+    await expect(page.getByLabel("다음 행동 요약")).toBeVisible();
+    await expect(page.getByLabel("가역성 요약")).toBeVisible();
+
+    await page.getByLabel("목표 명확도 높음").check();
+    await page.getByLabel("상품 이해도 보통").check();
+    await page.getByLabel("시간 압박 높음").check();
+    await page.getByLabel("유동성 필요 낮음").check();
+
+    await page.getByRole("button", { name: "진단 저장 및 다음 행동 보기" }).click();
+
+    const statusRegion = page.getByRole("status");
+    await expect(statusRegion).toContainText("저장 완료");
+    await expect(statusRegion).toContainText("다음 행동:", { timeout: 1000 });
+    await expect(statusRegion).toContainText("UI alias: state_assessed");
+    await expect(statusRegion).toContainText("저장 canonical: view_landing");
+  });
+
+  test("키보드만으로 진단 입력/제출/결과 확인이 가능하다", async ({ page }) => {
+    await page.goto("/");
+
+    await page.getByLabel("목표 명확도 높음").focus();
+    await page.keyboard.press("Space");
+    await page.getByLabel("상품 이해도 보통").focus();
+    await page.keyboard.press("Space");
+    await page.getByLabel("시간 압박 높음").focus();
+    await page.keyboard.press("Space");
+    await page.getByLabel("유동성 필요 낮음").focus();
+    await page.keyboard.press("Space");
+    await page.getByRole("button", { name: "진단 저장 및 다음 행동 보기" }).focus();
+    await page.keyboard.press("Enter");
+
+    const statusRegion = page.getByRole("status");
+    await expect(statusRegion).toContainText("저장 완료");
+    await expect(statusRegion).toContainText("다음 행동:");
+  });
+
+  test("모바일 뷰포트에서 진단 요약 블록이 초기 화면에 노출된다", async ({ page }) => {
+    await page.goto("/");
+
+    await expect(page.getByLabel("현재 상태 요약")).toBeVisible();
+    await expect(page.getByLabel("다음 행동 요약")).toBeVisible();
+    await expect(page.getByLabel("가역성 요약")).toBeVisible();
+  });
+
+  test("의향 입력 저장 후 동일 요청 재전송 시 중복 생성되지 않는다", async ({ page }) => {
+    await page.goto("/intent");
+
+    await expect(page.getByRole("heading", { name: "의향 입력" })).toBeVisible();
+    await page.getByLabel("자산 ID").fill(`asset_ui_${Date.now()}`);
+    await page.getByLabel("변경 근거 요약").fill("첫 저장");
+
+    await page.getByRole("button", { name: "의향 저장" }).click();
+    const statusRegion = page.getByRole("status");
+    await expect(statusRegion).toContainText("저장 완료 (정상 저장)");
+    await expect(statusRegion).toContainText("version: 1");
+
+    await page.getByRole("button", { name: "의향 저장" }).click();
+    await expect(statusRegion).toContainText("저장 완료 (재전송 동일응답)");
+    await expect(statusRegion).toContainText("version: 1");
+    await expect(statusRegion).toContainText("canonical: complete_intent_input");
+  });
+
+  test("회귀: intent/decision 경로가 계속 동작한다", async ({ page }) => {
+    await page.goto("/intent");
+    await expect(page).toHaveURL(/\/intent$/);
+    await expect(page.getByRole("heading", { name: "의향 입력" })).toBeVisible();
+
+    await page.goto("/decision");
+    await expect(page).toHaveURL(/\/decision$/);
+    await expect(page.getByRole("heading", { name: "판단 카드" })).toBeVisible();
+    await expect(page.getByLabel("decision-card-skeleton")).toBeAttached();
+  });
+});
diff --git a/tests/e2e/intent-record-api.contract.spec.ts b/tests/e2e/intent-record-api.contract.spec.ts
new file mode 100644
index 0000000..f84ce61
--- /dev/null
+++ b/tests/e2e/intent-record-api.contract.spec.ts
@@ -0,0 +1,235 @@
+import { expect, test } from "@playwright/test";
+
+const baseInput = {
+  assetId: "asset_contract_001",
+  intentType: "buy",
+  disposalIntentType: "upgrade",
+  timePressure: "medium",
+  liquidityNeed: "low",
+  budgetConstraint: {
+    min: 0,
+    max: 5000000,
+    currency: "KRW",
+  },
+  periodConstraint: {
+    startAt: "2026-04-06T00:00:00.000Z",
+    endAt: "2026-05-06T00:00:00.000Z",
+  },
+  isPublicIntent: true,
+  changeReasonSummary: "초기 저장",
+};
+
+test.describe("의향 저장 API 계약", () => {
+  test("생성 성공: data/meta 계약 및 canonical 이벤트를 반환한다", async ({ request }) => {
+    const response = await request.post("/api/intents/records", {
+      headers: {
+        "x-idempotency-key": crypto.randomUUID(),
+      },
+      data: {
+        input: {
+          ...baseInput,
+          assetId: `asset_contract_${crypto.randomUUID()}`,
+        },
+      },
+    });
+
+    expect(response.status()).toBe(200);
+    const payload = (await response.json()) as {
+      data: {
+        intentRecord: {
+          intentId: string;
+          assetId: string;
+          version: number;
+          updatedAt: string;
+        };
+      };
+      meta: {
+        idempotentReplay: boolean;
+        event: {
+          canonical: string;
+          eventId: string;
+          occurredAt: string;
+          traceId: string;
+          schemaVersion: number;
+        };
+      };
+    };
+
+    expect(payload.data.intentRecord.intentId).toMatch(/^ir_/);
+    expect(payload.data.intentRecord.version).toBe(1);
+    expect(Number.isNaN(Date.parse(payload.data.intentRecord.updatedAt))).toBeFalsy();
+    expect(payload.meta.idempotentReplay).toBeFalsy();
+    expect(payload.meta.event.canonical).toBe("complete_intent_input");
+  });
+
+  test("idempotency 재전송: 동일 key 재호출 시 중복 생성 없이 동일 결과를 반환한다", async ({
+    request,
+  }) => {
+    const idempotencyKey = crypto.randomUUID();
+    const assetId = `asset_idem_${crypto.randomUUID()}`;
+
+    const first = await request.post("/api/intents/records", {
+      headers: {
+        "x-idempotency-key": idempotencyKey,
+      },
+      data: {
+        input: {
+          ...baseInput,
+          assetId,
+        },
+      },
+    });
+    expect(first.status()).toBe(200);
+    const firstPayload = await first.json();
+
+    const replay = await request.post("/api/intents/records", {
+      headers: {
+        "x-idempotency-key": idempotencyKey,
+      },
+      data: {
+        input: {
+          ...baseInput,
+          assetId,
+        },
+      },
+    });
+    expect(replay.status()).toBe(200);
+    const replayPayload = await replay.json();
+
+    expect(replayPayload.meta.idempotentReplay).toBeTruthy();
+    expect(replayPayload.data.intentRecord.intentId).toBe(firstPayload.data.intentRecord.intentId);
+    expect(replayPayload.data.intentRecord.version).toBe(1);
+    expect(replayPayload.meta.event.eventId).toBe(firstPayload.meta.event.eventId);
+    expect(replayPayload.meta.event.traceId).toBe(firstPayload.meta.event.traceId);
+    expect(replayPayload.meta.event.schemaVersion).toBe(firstPayload.meta.event.schemaVersion);
+  });
+
+  test("idempotency key를 다른 payload로 재사용하면 409를 반환한다", async ({ request }) => {
+    const idempotencyKey = crypto.randomUUID();
+
+    const first = await request.post("/api/intents/records", {
+      headers: {
+        "x-idempotency-key": idempotencyKey,
+      },
+      data: {
+        input: {
+          ...baseInput,
+          assetId: `asset_idem_reuse_${crypto.randomUUID()}`,
+        },
+      },
+    });
+    expect(first.status()).toBe(200);
+
+    const conflict = await request.post("/api/intents/records", {
+      headers: {
+        "x-idempotency-key": idempotencyKey,
+      },
+      data: {
+        input: {
+          ...baseInput,
+          assetId: `asset_idem_reuse_${crypto.randomUUID()}`,
+          changeReasonSummary: "다른 요청 본문",
+        },
+      },
+    });
+
+    expect(conflict.status()).toBe(409);
+    const payload = await conflict.json();
+    expect(payload.error.code).toBe("IDEMPOTENCY_KEY_REUSED");
+  });
+
+  test("upsert 생성/수정: 동일 assetId 재저장 시 버전이 증가한다", async ({ request }) => {
+    const assetId = `asset_upsert_${crypto.randomUUID()}`;
+
+    const created = await request.post("/api/intents/records", {
+      data: {
+        input: {
+          ...baseInput,
+          assetId,
+        },
+      },
+    });
+    expect(created.status()).toBe(200);
+    const createdPayload = await created.json();
+
+    const updated = await request.post("/api/intents/records", {
+      data: {
+        input: {
+          ...baseInput,
+          assetId,
+          liquidityNeed: "high",
+          changeReasonSummary: "유동성 요구 증가",
+        },
+      },
+    });
+    expect(updated.status()).toBe(200);
+    const updatedPayload = await updated.json();
+
+    expect(updatedPayload.data.intentRecord.intentId).toBe(createdPayload.data.intentRecord.intentId);
+    expect(updatedPayload.data.intentRecord.version).toBe(2);
+    expect(updatedPayload.data.intentRecord.liquidityNeed).toBe("high");
+  });
+
+  test("유효성 실패: 잘못된 제약조건이면 INVALID_CONSTRAINT를 반환한다", async ({ request }) => {
+    const response = await request.post("/api/intents/records", {
+      data: {
+        input: {
+          ...baseInput,
+          assetId: `asset_invalid_${crypto.randomUUID()}`,
+          budgetConstraint: {
+            min: 200,
+            max: 100,
+            currency: "KRW",
+          },
+        },
+      },
+    });
+
+    expect(response.status()).toBe(400);
+    const payload = await response.json();
+    expect(payload.error.code).toBe("INVALID_CONSTRAINT");
+  });
+
+  test("유효성 실패: UTC가 아닌 periodConstraint는 INVALID_CONSTRAINT를 반환한다", async ({
+    request,
+  }) => {
+    const response = await request.post("/api/intents/records", {
+      data: {
+        input: {
+          ...baseInput,
+          assetId: `asset_invalid_tz_${crypto.randomUUID()}`,
+          periodConstraint: {
+            startAt: "2026-04-06T09:00:00.000+09:00",
+            endAt: "2026-05-06T09:00:00.000+09:00",
+          },
+        },
+      },
+    });
+
+    expect(response.status()).toBe(400);
+    const payload = await response.json();
+    expect(payload.error.code).toBe("INVALID_CONSTRAINT");
+  });
+
+  test("회귀: 기존 /api/intents 진단 계약은 그대로 유지된다", async ({ request }) => {
+    const response = await request.post("/api/intents", {
+      headers: {
+        "x-idempotency-key": crypto.randomUUID(),
+      },
+      data: {
+        input: {
+          goalClarity: "medium",
+          productClarity: "medium",
+          timePressure: "high",
+          liquidityNeed: "low",
+        },
+        uiEventAlias: "state_assessed",
+      },
+    });
+
+    expect(response.status()).toBe(200);
+    const payload = await response.json();
+    expect(payload.meta.event.canonical).toBe("view_landing");
+    expect(payload.data.diagnostic.next_step).toBeTruthy();
+  });
+});

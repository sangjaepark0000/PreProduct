diff --git a/scripts/bmad-git.ps1 b/scripts/bmad-git.ps1
new file mode 100644
index 0000000..f3a2ad8
--- /dev/null
+++ b/scripts/bmad-git.ps1
@@ -0,0 +1,315 @@
+[CmdletBinding()]
+param(
+  [Parameter(Position = 0)]
+  [ValidateSet('init', 'commit', 'self-check')]
+  [string]$Mode,
+
+  [string]$Slug,
+  [string]$Phase,
+  [string]$Tag = 'auto',
+  [string]$RepositoryPath,
+  [string]$BranchPrefix,
+  [string]$CommitPattern,
+  [switch]$CreateBaselineCommit,
+  [switch]$DryRun
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+if (Get-Variable -Name PSNativeCommandUseErrorActionPreference -ErrorAction SilentlyContinue) {
+  $PSNativeCommandUseErrorActionPreference = $false
+}
+
+function Fail([string]$Message) {
+  Write-Output "ERROR: $Message"
+  exit 1
+}
+
+function Test-ValidSlug([string]$Value) {
+  return $Value -match '^[a-z0-9]+(?:-[a-z0-9]+)*$'
+}
+
+function Test-ValidPhase([string]$Value) {
+  return $Value -match '^[a-z0-9]+(?:-[a-z0-9]+)*$'
+}
+
+function Test-ValidTag([string]$Value) {
+  return $Value -match '^[a-z0-9]+(?:-[a-z0-9]+)*$'
+}
+
+function Get-BmadGitDefaults {
+  $result = @{
+    BranchPrefix = 'feat'
+    CommitPattern = 'bmad({phase}): {slug} [{tag}]'
+  }
+
+  $configCandidates = @(
+    (Join-Path (Resolve-Path -Path (Join-Path $PSScriptRoot '..')).Path '_bmad/bmm/config.yaml'),
+    (Join-Path (Get-Location).Path '_bmad/bmm/config.yaml')
+  ) | Select-Object -Unique
+
+  $configPath = $null
+  foreach ($candidate in $configCandidates) {
+    if (Test-Path $candidate) {
+      $configPath = $candidate
+      break
+    }
+  }
+
+  if (-not $configPath) {
+    return $result
+  }
+
+  $lines = Get-Content -Path $configPath
+  $inBlock = $false
+  foreach ($line in $lines) {
+    if ($line -match '^\s*bmad_git:\s*$') {
+      $inBlock = $true
+      continue
+    }
+
+    if (-not $inBlock) {
+      continue
+    }
+
+    if ($line -match '^\S') {
+      break
+    }
+
+    if ($line -match '^\s*branch_prefix:\s*"?([^"#\r\n]+)"?\s*$') {
+      $result.BranchPrefix = $Matches[1].Trim()
+      continue
+    }
+
+    if ($line -match '^\s*commit_pattern:\s*"?([^"\r\n]+)"?\s*$') {
+      $result.CommitPattern = $Matches[1].Trim()
+      continue
+    }
+  }
+
+  return $result
+}
+
+function Resolve-RepoCandidate([string]$PathValue) {
+  try {
+    return (Resolve-Path -Path $PathValue -ErrorAction Stop).Path
+  } catch {
+    return $null
+  }
+}
+
+function Get-GitTopLevel([string]$Candidate) {
+  $output = & cmd /c "git -C `"$Candidate`" rev-parse --show-toplevel 2>nul"
+  if ($LASTEXITCODE -ne 0) {
+    return $null
+  }
+
+  $joined = ($output -join "`n").Trim()
+  if ([string]::IsNullOrWhiteSpace($joined)) {
+    return $null
+  }
+
+  return $joined
+}
+
+function Find-GitRepo([string]$ExplicitPath) {
+  $candidates = @()
+
+  if ($ExplicitPath) {
+    $resolved = Resolve-RepoCandidate -PathValue $ExplicitPath
+    if (-not $resolved) {
+      Fail "Git repository path is invalid: $ExplicitPath"
+    }
+    $candidates += $resolved
+  } else {
+    $candidates += (Get-Location).Path
+
+    $workspaceRoot = (Resolve-Path -Path (Join-Path $PSScriptRoot '..')).Path
+    $candidates += $workspaceRoot
+
+    $children = Get-ChildItem -Path $workspaceRoot -Directory -ErrorAction SilentlyContinue
+    foreach ($child in $children) {
+      if (Test-Path (Join-Path $child.FullName '.git')) {
+        $candidates += $child.FullName
+      }
+    }
+  }
+
+  $validRepos = @()
+  foreach ($candidate in ($candidates | Select-Object -Unique)) {
+    $top = Get-GitTopLevel -Candidate $candidate
+    if (-not [string]::IsNullOrWhiteSpace($top)) {
+      $validRepos += (Resolve-Path -Path $top).Path
+    }
+  }
+
+  $validRepos = @($validRepos | Select-Object -Unique)
+
+  if ($validRepos.Count -eq 0) {
+    return $null
+  }
+
+  if (-not $ExplicitPath -and $validRepos.Count -gt 1) {
+    $joined = $validRepos -join ', '
+    Fail "Multiple Git repositories found: $joined. Use -RepositoryPath to select one."
+  }
+
+  return $validRepos[0]
+}
+
+function Get-DirtyState([string]$Repo) {
+  $status = & git -C $Repo status --porcelain
+  return -not [string]::IsNullOrWhiteSpace(($status -join "`n"))
+}
+
+function Test-BranchExists([string]$Repo, [string]$BranchName) {
+  & git -C $Repo show-ref --verify --quiet "refs/heads/$BranchName"
+  return $LASTEXITCODE -eq 0
+}
+
+function Ensure-CheckedOutBranch([string]$Repo, [string]$BranchName) {
+  if (Test-BranchExists -Repo $Repo -BranchName $BranchName) {
+    if ($DryRun) {
+      Write-Output "[dry-run] git -C $Repo checkout $BranchName"
+      return
+    }
+
+    & git -C $Repo checkout $BranchName | Out-Null
+    if ($LASTEXITCODE -ne 0) { Fail "Failed to checkout existing branch: $BranchName" }
+    Write-Output "Checked out branch: $BranchName"
+    return
+  }
+
+  if ($DryRun) {
+    Write-Output "[dry-run] git -C $Repo checkout -b $BranchName"
+    return
+  }
+
+  & git -C $Repo checkout -b $BranchName | Out-Null
+  if ($LASTEXITCODE -ne 0) { Fail "Failed to create branch: $BranchName" }
+  Write-Output "Created branch: $BranchName"
+}
+
+function Format-CommitMessage([string]$Pattern, [string]$MsgSlug, [string]$MsgPhase, [string]$MsgTag) {
+  $message = $Pattern.Replace('{slug}', $MsgSlug)
+  $message = $message.Replace('{phase}', $MsgPhase)
+  $message = $message.Replace('{tag}', $MsgTag)
+  return $message
+}
+
+function New-BmadCommit([string]$Repo, [string]$Message) {
+  $isDirty = Get-DirtyState -Repo $Repo
+  if (-not $isDirty) {
+    Write-Output 'No changes detected: commit skipped'
+    return
+  }
+
+  if ($DryRun) {
+    Write-Output "[dry-run] git -C $Repo add -A"
+    Write-Output "[dry-run] git -C $Repo commit -m `"$Message`""
+    return
+  }
+
+  & git -C $Repo add -A
+  if ($LASTEXITCODE -ne 0) { Fail 'git add failed' }
+
+  & git -C $Repo commit -m $Message | Out-Null
+  if ($LASTEXITCODE -ne 0) { Fail 'git commit failed' }
+
+  Write-Output "Created commit: $Message"
+}
+
+function Run-InitMode {
+  if (-not $Slug) { Fail 'init mode requires -Slug' }
+  if (-not (Test-ValidSlug $Slug)) { Fail 'Invalid slug format. Example: bmad-git-automation' }
+
+  $repo = Find-GitRepo -ExplicitPath $RepositoryPath
+  if (-not $repo) { Fail 'Could not find a Git repository. Provide -RepositoryPath.' }
+
+  $branchName = "$BranchPrefix/$Slug"
+
+  if ($CreateBaselineCommit) {
+    $baselineMessage = Format-CommitMessage -Pattern $CommitPattern -MsgSlug $Slug -MsgPhase 'init' -MsgTag 'baseline'
+    New-BmadCommit -Repo $repo -Message $baselineMessage
+  }
+
+  Ensure-CheckedOutBranch -Repo $repo -BranchName $branchName
+  Write-Output "repo=$repo"
+}
+
+function Run-CommitMode {
+  if (-not $Slug) { Fail 'commit mode requires -Slug' }
+  if (-not (Test-ValidSlug $Slug)) { Fail 'Invalid slug format. Example: bmad-git-automation' }
+  if (-not $Phase) { Fail 'commit mode requires -Phase' }
+  if (-not (Test-ValidPhase $Phase)) { Fail 'Invalid phase format. Example: step-03' }
+  if (-not (Test-ValidTag $Tag)) { Fail 'Invalid tag format. Example: auto or review-pass-1' }
+
+  $repo = Find-GitRepo -ExplicitPath $RepositoryPath
+  if (-not $repo) { Fail 'Could not find a Git repository. Provide -RepositoryPath.' }
+
+  $branchName = "$BranchPrefix/$Slug"
+  Ensure-CheckedOutBranch -Repo $repo -BranchName $branchName
+
+  $message = Format-CommitMessage -Pattern $CommitPattern -MsgSlug $Slug -MsgPhase $Phase -MsgTag $Tag
+  New-BmadCommit -Repo $repo -Message $message
+  Write-Output "repo=$repo"
+}
+
+function Run-SelfCheckMode {
+  $repo = Find-GitRepo -ExplicitPath $RepositoryPath
+  if (-not $repo) { Fail 'Could not find a Git repository. Provide -RepositoryPath.' }
+
+  $tempRepo = Join-Path ([System.IO.Path]::GetTempPath()) ("bmad-git-selfcheck-" + [Guid]::NewGuid().ToString('N'))
+  New-Item -ItemType Directory -Path $tempRepo | Out-Null
+  & git -C $tempRepo init | Out-Null
+  if ($LASTEXITCODE -ne 0) { Fail 'Failed to create temp repo for self-check' }
+  & git -C $tempRepo config user.name "bmad-self-check" | Out-Null
+  & git -C $tempRepo config user.email "bmad-self-check@example.invalid" | Out-Null
+  & git -C $tempRepo commit --allow-empty -m "seed" | Out-Null
+  & git -C $tempRepo checkout -b feat/test-branch | Out-Null
+
+  $checks = @(
+    @{ Name = 'slug-valid'; Pass = (Test-ValidSlug 'bmad-git-automation') },
+    @{ Name = 'slug-invalid'; Pass = (-not (Test-ValidSlug 'bad_slug')) },
+    @{ Name = 'phase-valid'; Pass = (Test-ValidPhase 'step-03') },
+    @{ Name = 'phase-invalid'; Pass = (-not (Test-ValidPhase 'step_03')) },
+    @{ Name = 'tag-valid'; Pass = (Test-ValidTag 'auto') },
+    @{ Name = 'tag-invalid'; Pass = (-not (Test-ValidTag 'bad tag')) },
+    @{ Name = 'repo-detected'; Pass = $true },
+    @{ Name = 'branch-duplicate-detected'; Pass = (Test-BranchExists -Repo $tempRepo -BranchName 'feat/test-branch') },
+    @{ Name = 'clean-repo-skip-path'; Pass = (-not (Get-DirtyState -Repo $tempRepo)) }
+  )
+
+  Remove-Item -LiteralPath $tempRepo -Recurse -Force
+
+  $failed = @($checks | Where-Object { -not $_.Pass })
+  foreach ($check in $checks) {
+    $state = if ($check.Pass) { 'PASS' } else { 'FAIL' }
+    Write-Output ("[{0}] {1}" -f $state, $check.Name)
+  }
+
+  if ($failed.Count -gt 0) {
+    Fail 'self-check failed'
+  }
+
+  Write-Output "self-check completed: repo=$repo"
+}
+
+$defaults = Get-BmadGitDefaults
+if (-not $BranchPrefix) {
+  $BranchPrefix = $defaults.BranchPrefix
+}
+if (-not $CommitPattern) {
+  $CommitPattern = $defaults.CommitPattern
+}
+
+if (-not $Mode) {
+  Fail 'Specify Mode: init | commit | self-check'
+}
+
+switch ($Mode) {
+  'init' { Run-InitMode }
+  'commit' { Run-CommitMode }
+  'self-check' { Run-SelfCheckMode }
+  default { Fail 'Unsupported mode' }
+}

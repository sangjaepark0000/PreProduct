diff --git a/src/feature/intent/components/intent-form.tsx b/src/feature/intent/components/intent-form.tsx
new file mode 100644
index 0000000..6638c7e
--- /dev/null
+++ b/src/feature/intent/components/intent-form.tsx
@@ -0,0 +1,374 @@
+"use client";
+
+import { useMemo, useState } from "react";
+import styles from "./intent-form.module.css";
+import {
+  DISPOSAL_INTENT_TYPE_VALUES,
+  INTENT_TYPE_VALUES,
+  type DisposalIntentType,
+  type IntentType,
+  type LiquidityNeed,
+  type TimePressure,
+} from "@/shared/contracts/intent-record";
+
+type IntentFormState = {
+  assetId: string;
+  intentType: IntentType;
+  disposalIntentType: DisposalIntentType;
+  timePressure: TimePressure;
+  liquidityNeed: LiquidityNeed;
+  budgetMin: string;
+  budgetMax: string;
+  budgetCurrency: string;
+  periodStartAt: string;
+  periodEndAt: string;
+  isPublicIntent: boolean;
+  changeReasonSummary: string;
+};
+
+type IntentApiPayload = {
+  data: {
+    intentRecord: {
+      intentId: string;
+      assetId: string;
+      version: number;
+      updatedAt: string;
+      isPublicIntent: boolean;
+      changeReasonSummary: string;
+    };
+  };
+  meta: {
+    idempotentReplay: boolean;
+    event?: {
+      canonical?: string;
+    };
+  };
+};
+
+const PRIORITY_OPTIONS: { value: "low" | "medium" | "high"; label: string }[] = [
+  { value: "low", label: "낮음" },
+  { value: "medium", label: "보통" },
+  { value: "high", label: "높음" },
+];
+
+const INTENT_LABELS: Record<IntentType, string> = {
+  buy: "매수",
+  sell: "매도",
+  hold: "보유",
+};
+
+const DISPOSAL_LABELS: Record<DisposalIntentType, string> = {
+  upgrade: "갈아타기",
+  exit: "청산",
+  liquidity: "현금화",
+};
+
+const INITIAL_FORM: IntentFormState = {
+  assetId: "asset_krw_stock_001",
+  intentType: "buy",
+  disposalIntentType: "upgrade",
+  timePressure: "medium",
+  liquidityNeed: "medium",
+  budgetMin: "0",
+  budgetMax: "10000000",
+  budgetCurrency: "KRW",
+  periodStartAt: "2026-04-06T00:00:00.000Z",
+  periodEndAt: "2026-05-06T00:00:00.000Z",
+  isPublicIntent: true,
+  changeReasonSummary: "초기 의향 등록",
+};
+
+export function IntentForm() {
+  const [form, setForm] = useState<IntentFormState>(INITIAL_FORM);
+  const [isSubmitting, setIsSubmitting] = useState(false);
+  const [idempotencyKey] = useState(() => crypto.randomUUID());
+  const [saveStatus, setSaveStatus] = useState("아직 저장 전");
+  const [recordInfo, setRecordInfo] = useState({
+    intentId: "-",
+    version: "-",
+    updatedAt: "-",
+    canonical: "-",
+  });
+
+  const summaryItems = useMemo(
+    () => [
+      { label: "자산", value: form.assetId },
+      { label: "의향", value: INTENT_LABELS[form.intentType] },
+      { label: "처분유형", value: DISPOSAL_LABELS[form.disposalIntentType] },
+      { label: "공개", value: form.isPublicIntent ? "공개" : "비공개" },
+    ],
+    [form.assetId, form.disposalIntentType, form.intentType, form.isPublicIntent],
+  );
+
+  function updateField<K extends keyof IntentFormState>(field: K, value: IntentFormState[K]) {
+    setForm((prev) => ({ ...prev, [field]: value }));
+  }
+
+  async function handleSubmit(event: React.FormEvent<HTMLFormElement>) {
+    event.preventDefault();
+    setIsSubmitting(true);
+    setSaveStatus("저장 중");
+
+    try {
+      const response = await fetch("/api/intents/records", {
+        method: "POST",
+        headers: {
+          "content-type": "application/json",
+          "x-idempotency-key": idempotencyKey,
+        },
+        body: JSON.stringify({
+          input: {
+            assetId: form.assetId,
+            intentType: form.intentType,
+            disposalIntentType: form.disposalIntentType,
+            timePressure: form.timePressure,
+            liquidityNeed: form.liquidityNeed,
+            budgetConstraint: {
+              min: Number(form.budgetMin),
+              max: Number(form.budgetMax),
+              currency: form.budgetCurrency,
+            },
+            periodConstraint: {
+              startAt: form.periodStartAt,
+              endAt: form.periodEndAt,
+            },
+            isPublicIntent: form.isPublicIntent,
+            changeReasonSummary: form.changeReasonSummary,
+          },
+        }),
+      });
+
+      if (!response.ok) {
+        setSaveStatus("저장 실패");
+        return;
+      }
+
+      const payload = (await response.json()) as IntentApiPayload;
+      const replayLabel = payload.meta.idempotentReplay ? "재전송 동일응답" : "정상 저장";
+      setSaveStatus(`저장 완료 (${replayLabel})`);
+      setRecordInfo({
+        intentId: payload.data.intentRecord.intentId,
+        version: String(payload.data.intentRecord.version),
+        updatedAt: payload.data.intentRecord.updatedAt,
+        canonical: payload.meta.event?.canonical ?? "-",
+      });
+    } catch {
+      setSaveStatus("저장 실패");
+    } finally {
+      setIsSubmitting(false);
+    }
+  }
+
+  return (
+    <section className={styles.container} aria-label="의향 입력 섹션">
+      <div className={styles.summaryGrid}>
+        {summaryItems.map((item) => (
+          <article key={item.label} className={styles.summaryCard} aria-label={`${item.label} 요약`}>
+            <p className={styles.summaryLabel}>[i] {item.label}</p>
+            <p className={styles.summaryValue}>{item.value}</p>
+          </article>
+        ))}
+      </div>
+
+      <form className={styles.form} onSubmit={handleSubmit}>
+        <h2>자산 단위 의향 등록</h2>
+
+        <label className={styles.fieldLabel} htmlFor="assetId">
+          자산 ID
+        </label>
+        <input
+          id="assetId"
+          className={styles.textField}
+          name="assetId"
+          value={form.assetId}
+          onChange={(event) => updateField("assetId", event.target.value)}
+          required
+        />
+
+        <fieldset className={styles.fieldset}>
+          <legend className={styles.legend}>의향 유형</legend>
+          <div className={styles.optionRow}>
+            {INTENT_TYPE_VALUES.map((value) => (
+              <label key={value} className={styles.optionLabel}>
+                <input
+                  type="radio"
+                  name="intentType"
+                  value={value}
+                  checked={form.intentType === value}
+                  onChange={() => updateField("intentType", value)}
+                />
+                <span>{INTENT_LABELS[value]}</span>
+              </label>
+            ))}
+          </div>
+        </fieldset>
+
+        <fieldset className={styles.fieldset}>
+          <legend className={styles.legend}>처분 의향 유형</legend>
+          <div className={styles.optionRow}>
+            {DISPOSAL_INTENT_TYPE_VALUES.map((value) => (
+              <label key={value} className={styles.optionLabel}>
+                <input
+                  type="radio"
+                  name="disposalIntentType"
+                  value={value}
+                  checked={form.disposalIntentType === value}
+                  onChange={() => updateField("disposalIntentType", value)}
+                />
+                <span>{DISPOSAL_LABELS[value]}</span>
+              </label>
+            ))}
+          </div>
+        </fieldset>
+
+        <PriorityField
+          legend="시간 압박"
+          fieldName="timePressure"
+          selected={form.timePressure}
+          onSelect={(value) => updateField("timePressure", value)}
+        />
+
+        <PriorityField
+          legend="유동성 필요"
+          fieldName="liquidityNeed"
+          selected={form.liquidityNeed}
+          onSelect={(value) => updateField("liquidityNeed", value)}
+        />
+
+        <div className={styles.constraintGrid}>
+          <div>
+            <label className={styles.fieldLabel} htmlFor="budgetMin">
+              예산 최소값
+            </label>
+            <input
+              id="budgetMin"
+              className={styles.textField}
+              type="number"
+              min={0}
+              value={form.budgetMin}
+              onChange={(event) => updateField("budgetMin", event.target.value)}
+              required
+            />
+          </div>
+          <div>
+            <label className={styles.fieldLabel} htmlFor="budgetMax">
+              예산 최대값
+            </label>
+            <input
+              id="budgetMax"
+              className={styles.textField}
+              type="number"
+              min={0}
+              value={form.budgetMax}
+              onChange={(event) => updateField("budgetMax", event.target.value)}
+              required
+            />
+          </div>
+          <div>
+            <label className={styles.fieldLabel} htmlFor="budgetCurrency">
+              통화
+            </label>
+            <input
+              id="budgetCurrency"
+              className={styles.textField}
+              value={form.budgetCurrency}
+              onChange={(event) => updateField("budgetCurrency", event.target.value)}
+              required
+            />
+          </div>
+        </div>
+
+        <div className={styles.constraintGrid}>
+          <div>
+            <label className={styles.fieldLabel} htmlFor="periodStartAt">
+              시작 시각(UTC)
+            </label>
+            <input
+              id="periodStartAt"
+              className={styles.textField}
+              value={form.periodStartAt}
+              onChange={(event) => updateField("periodStartAt", event.target.value)}
+              required
+            />
+          </div>
+          <div>
+            <label className={styles.fieldLabel} htmlFor="periodEndAt">
+              종료 시각(UTC)
+            </label>
+            <input
+              id="periodEndAt"
+              className={styles.textField}
+              value={form.periodEndAt}
+              onChange={(event) => updateField("periodEndAt", event.target.value)}
+              required
+            />
+          </div>
+        </div>
+
+        <label className={styles.switchLabel} htmlFor="publicIntentToggle">
+          <input
+            id="publicIntentToggle"
+            type="checkbox"
+            checked={form.isPublicIntent}
+            onChange={(event) => updateField("isPublicIntent", event.target.checked)}
+          />
+          <span>{form.isPublicIntent ? "[O] 선의향 공개" : "[X] 선의향 비공개"}</span>
+        </label>
+
+        <label className={styles.fieldLabel} htmlFor="changeReasonSummary">
+          변경 근거 요약
+        </label>
+        <textarea
+          id="changeReasonSummary"
+          className={styles.textArea}
+          value={form.changeReasonSummary}
+          onChange={(event) => updateField("changeReasonSummary", event.target.value)}
+          required
+        />
+
+        <p className={styles.hint}>[!] 색상만으로 상태를 전달하지 않고 텍스트/아이콘을 함께 노출합니다.</p>
+
+        <button className={styles.submitButton} type="submit" disabled={isSubmitting}>
+          {isSubmitting ? "저장 중..." : "의향 저장"}
+        </button>
+      </form>
+
+      <div className={styles.statusBox} role="status" aria-live="polite">
+        <p className={styles.statusText}>{saveStatus}</p>
+        <p>intentId: {recordInfo.intentId}</p>
+        <p>version: {recordInfo.version}</p>
+        <p>updatedAt: {recordInfo.updatedAt}</p>
+        <p>canonical: {recordInfo.canonical}</p>
+      </div>
+    </section>
+  );
+}
+
+type PriorityFieldProps = {
+  legend: string;
+  fieldName: "timePressure" | "liquidityNeed";
+  selected: "low" | "medium" | "high";
+  onSelect: (value: "low" | "medium" | "high") => void;
+};
+
+function PriorityField({ legend, fieldName, selected, onSelect }: PriorityFieldProps) {
+  return (
+    <fieldset className={styles.fieldset}>
+      <legend className={styles.legend}>{legend}</legend>
+      <div className={styles.optionRow}>
+        {PRIORITY_OPTIONS.map((option) => (
+          <label key={`${fieldName}-${option.value}`} className={styles.optionLabel}>
+            <input
+              type="radio"
+              name={fieldName}
+              value={option.value}
+              checked={selected === option.value}
+              onChange={() => onSelect(option.value)}
+            />
+            <span>{option.label}</span>
+          </label>
+        ))}
+      </div>
+    </fieldset>
+  );
+}

+import type {
+  IntentRecordDto,
+  IntentRecordInputDto,
+  IntentRecordResponseDto,
+} from "@/shared/contracts/intent-record";
+
+const intentStore = new Map<string, IntentRecordDto>();
+const idempotencyStore = new Map<string, IntentRecordResponseDto>();
+
+export function getIntentRecordReplay(idempotencyKey: string): IntentRecordResponseDto | undefined {
+  return idempotencyStore.get(idempotencyKey);
+}
+
+export function rememberIntentRecordReplay(idempotencyKey: string, response: IntentRecordResponseDto) {
+  idempotencyStore.set(idempotencyKey, response);
+}
+
+export function upsertIntentRecord(input: IntentRecordInputDto, nowIso: string): IntentRecordDto {
+  const existing = intentStore.get(input.assetId);
+
+  if (!existing) {
+    const created: IntentRecordDto = {
+      intentId: `ir_${crypto.randomUUID()}`,
+      assetId: input.assetId,
+      intentType: input.intentType,
+      disposalIntentType: input.disposalIntentType,
+      timePressure: input.timePressure,
+      liquidityNeed: input.liquidityNeed,
+      budgetConstraint: input.budgetConstraint,
+      periodConstraint: input.periodConstraint,
+      isPublicIntent: input.isPublicIntent,
+      version: 1,
+      updatedAt: nowIso,
+      changeReasonSummary: input.changeReasonSummary,
+    };
+
+    intentStore.set(created.assetId, created);
+    return created;
+  }
+
+  const updated: IntentRecordDto = {
+    ...existing,
+    intentType: input.intentType,
+    disposalIntentType: input.disposalIntentType,
+    timePressure: input.timePressure,
+    liquidityNeed: input.liquidityNeed,
+    budgetConstraint: input.budgetConstraint,
+    periodConstraint: input.periodConstraint,
+    isPublicIntent: input.isPublicIntent,
+    version: existing.version + 1,
+    updatedAt: nowIso,
+    changeReasonSummary: input.changeReasonSummary,
+  };
+
+  intentStore.set(updated.assetId, updated);
+  return updated;
+}
+
+export function getIntentRecordCountByAsset(assetId: string): number {
+  return intentStore.has(assetId) ? 1 : 0;
+}
diff --git a/src/domain/intent/intent-record-validator.ts b/src/domain/intent/intent-record-validator.ts

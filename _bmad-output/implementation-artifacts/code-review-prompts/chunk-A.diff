+function getEnvValue(key: "NEXT_PUBLIC_APP_NAME", fallback?: string): string {
+  const value = process.env[key];
+  if (!value) {
+    if (fallback) {
+      return fallback;
+    }
+    throw new Error(`Missing required environment variable: ${key}`);
+  }
+  return value;
+}
+
+export const env = {
+  NEXT_PUBLIC_APP_NAME: getEnvValue("NEXT_PUBLIC_APP_NAME", "PreProduct"),
+};

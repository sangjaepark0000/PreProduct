@@ -0,0 +1,188 @@
+import { NextResponse } from "next/server";
+import type { ApiError, ApiSuccess } from "@/shared/contracts/api-response";
+import {
+  EVENT_ALIAS_TO_CANONICAL,
+  GOAL_CLARITY_VALUES,
+  LIQUIDITY_NEED_VALUES,
+  PRODUCT_CLARITY_VALUES,
+  TIME_PRESSURE_VALUES,
+  type GoalConfidence,
+  type IntentDiagnosticInputDto,
+  type IntentDiagnosticRequestDto,
+  type IntentDiagnosticResultDto,
+  type IntentMaturity,
+} from "@/shared/contracts/intent-diagnostic";
+
+type IntentApiData = {
+  diagnostic: IntentDiagnosticResultDto;
+};
+
+const idemStore = new Map<string, ApiSuccess<IntentApiData>>();
+
+function isEnumValue<T extends readonly string[]>(value: unknown, values: T): value is T[number] {
+  return typeof value === "string" && values.includes(value);
+}
+
+function validateInput(input: unknown): input is IntentDiagnosticInputDto {
+  if (typeof input !== "object" || input === null) {
+    return false;
+  }
+
+  const candidate = input as Partial<IntentDiagnosticInputDto>;
+  return (
+    isEnumValue(candidate.goalClarity, GOAL_CLARITY_VALUES) &&
+    isEnumValue(candidate.productClarity, PRODUCT_CLARITY_VALUES) &&
+    isEnumValue(candidate.timePressure, TIME_PRESSURE_VALUES) &&
+    isEnumValue(candidate.liquidityNeed, LIQUIDITY_NEED_VALUES)
+  );
+}
+
+function buildError(
+  requestId: string,
+  code: string,
+  message: string,
+  details?: Record<string, unknown>,
+): ApiError {
+  return {
+    error: {
+      code,
+      message,
+      details,
+      requestId,
+    },
+  };
+}
+
+function toNumeric(value: "low" | "medium" | "high"): number {
+  if (value === "low") return 1;
+  if (value === "high") return 3;
+  return 2;
+}
+
+function deriveDiagnostic(input: IntentDiagnosticInputDto): IntentDiagnosticResultDto {
+  const goalScore = toNumeric(input.goalClarity);
+  const productScore = toNumeric(input.productClarity);
+  const timeScore = toNumeric(input.timePressure);
+  const liquidityScore = toNumeric(input.liquidityNeed);
+
+  const clarityAverage = (goalScore + productScore) / 2;
+  const pressureAverage = (timeScore + liquidityScore) / 2;
+
+  let intentMaturity: IntentMaturity = "explore";
+  let goalConfidence: GoalConfidence = "low";
+  let nextStep = "탐색 시작: 관심 상품 2개를 비교해 차이를 기록하세요.";
+  let reversibilityHint = "가벼운 비교부터 시작해도 되며, 언제든 기준을 바꿀 수 있습니다.";
+
+  if (clarityAverage >= 2.5 && pressureAverage >= 2.5) {
+    intentMaturity = "prepare";
+    goalConfidence = "high";
+    nextStep = "판단 준비: 우선순위 기준 3가지를 고정하고 즉시 판단 카드로 이동하세요.";
+    reversibilityHint = "기준 확정 후에도 다음 세션에서 기준 가중치를 조정할 수 있습니다.";
+  } else if (clarityAverage >= 1.75) {
+    intentMaturity = "refine";
+    goalConfidence = "medium";
+    nextStep = "의향 보완: 목표 기간과 허용 손실 범위를 먼저 채우세요.";
+    reversibilityHint = "입력한 의향은 언제든 수정 가능하며 결정은 보류할 수 있습니다.";
+  }
+
+  return {
+    intent_maturity: intentMaturity,
+    goal_confidence: goalConfidence,
+    next_step: nextStep,
+    reversibility_hint: reversibilityHint,
+    occurredAt: new Date().toISOString(),
+  };
+}
+
+export async function POST(request: Request) {
+  const requestId = crypto.randomUUID();
+  const traceId = request.headers.get("x-trace-id") ?? requestId;
+  const idempotencyKey = request.headers.get("x-idempotency-key");
+
+  let body: unknown;
+  try {
+    body = await request.json();
+  } catch {
+    return NextResponse.json(
+      buildError(requestId, "INVALID_JSON", "JSON 본문을 파싱할 수 없습니다.", {
+        traceId,
+      }),
+      { status: 400 },
+    );
+  }
+
+  if (typeof body !== "object" || body === null) {
+    return NextResponse.json(
+      buildError(requestId, "INVALID_BODY", "요청 본문은 객체여야 합니다.", {
+        traceId,
+      }),
+      { status: 400 },
+    );
+  }
+
+  const payload = body as Partial<IntentDiagnosticRequestDto>;
+  if (!validateInput(payload.input)) {
+    return NextResponse.json(
+      buildError(requestId, "INVALID_INPUT", "필수 필드가 누락되었거나 범위를 벗어났습니다.", {
+        expected: {
+          goalClarity: GOAL_CLARITY_VALUES,
+          productClarity: PRODUCT_CLARITY_VALUES,
+          timePressure: TIME_PRESSURE_VALUES,
+          liquidityNeed: LIQUIDITY_NEED_VALUES,
+        },
+        traceId,
+      }),
+      { status: 400 },
+    );
+  }
+
+  if (payload.uiEventAlias !== "state_assessed") {
+    return NextResponse.json(
+      buildError(requestId, "INVALID_EVENT_ALIAS", "지원하지 않는 UI 이벤트 별칭입니다.", {
+        expected: "state_assessed",
+        traceId,
+      }),
+      { status: 400 },
+    );
+  }
+
+  if (idempotencyKey && idemStore.has(idempotencyKey)) {
+    const replay = idemStore.get(idempotencyKey);
+    return NextResponse.json(
+      {
+        ...replay,
+        meta: {
+          ...replay?.meta,
+          requestId,
+          traceId,
+          idempotentReplay: true,
+          event: {
+            canonical: EVENT_ALIAS_TO_CANONICAL[payload.uiEventAlias],
+          },
+        },
+      },
+      { status: 200 },
+    );
+  }
+
+  const diagnostic = deriveDiagnostic(payload.input);
+  const response: ApiSuccess<IntentApiData> = {
+    data: {
+      diagnostic,
+    },
+    meta: {
+      requestId,
+      traceId,
+      idempotentReplay: false,
+      event: {
+        canonical: EVENT_ALIAS_TO_CANONICAL[payload.uiEventAlias],
+      },
+    },
+  };
+
+  if (idempotencyKey) {
+    idemStore.set(idempotencyKey, response);
+  }
+
+  return NextResponse.json(response, { status: 200 });
+}

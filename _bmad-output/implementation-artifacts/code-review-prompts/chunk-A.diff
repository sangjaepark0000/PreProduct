+import type {
+  IntentRecordEventCanonical,
+  IntentRecordEventName,
+} from "@/shared/contracts/intent-record";
+
+export type IntentEventEnvelope = {
+  eventId: string;
+  eventName: IntentRecordEventName;
+  canonical: IntentRecordEventCanonical;
+  occurredAt: string;
+  traceId: string;
+  schemaVersion: number;
+};
+
+const dedupeKeys = new Set<string>();
+
+export function recordIntentEvent(
+  eventName: IntentRecordEventName,
+  canonical: IntentRecordEventCanonical,
+  traceId: string,
+  dedupeKey: string,
+): { envelope: IntentEventEnvelope; duplicated: boolean } {
+  const dedupeToken = `${eventName}:${dedupeKey}`;
+  const duplicated = dedupeKeys.has(dedupeToken);
+
+  if (!duplicated) {
+    dedupeKeys.add(dedupeToken);
+  }
+
+  return {
+    duplicated,
+    envelope: {
+      eventId: `evt_${crypto.randomUUID()}`,
+      eventName,
+      canonical,
+      occurredAt: new Date().toISOString(),
+      traceId,
+      schemaVersion: 1,
+    },
+  };
+}

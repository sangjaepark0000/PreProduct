+++ b/src/infra/mapper/intent-record-mapper.ts
@@ -0,0 +1,35 @@
+import type { IntentRecordRequestDto } from "@/shared/contracts/intent-record";
+import { mapTopLevelKeysSnakeToCamel } from "@/infra/mapper/case-mapper";
+
+function mapConstraintKeys(value: unknown): unknown {
+  if (typeof value !== "object" || value === null) {
+    return value;
+  }
+
+  return mapTopLevelKeysSnakeToCamel(value as Record<string, unknown>);
+}
+
+export function mapIntentRecordRequest(body: unknown): Partial<IntentRecordRequestDto> {
+  if (typeof body !== "object" || body === null) {
+    return {};
+  }
+
+  const mapped = mapTopLevelKeysSnakeToCamel(body as Record<string, unknown>);
+  const input = mapped.input;
+  if (typeof input !== "object" || input === null) {
+    return mapped as Partial<IntentRecordRequestDto>;
+  }
+
+  const mappedInput = mapTopLevelKeysSnakeToCamel(input as Record<string, unknown>);
+  const budgetConstraint = mapConstraintKeys(mappedInput.budgetConstraint);
+  const periodConstraint = mapConstraintKeys(mappedInput.periodConstraint);
+
+  return {
+    ...mapped,
+    input: {
+      ...mappedInput,
+      budgetConstraint,
+      periodConstraint,
+    },
+  } as Partial<IntentRecordRequestDto>;
+}

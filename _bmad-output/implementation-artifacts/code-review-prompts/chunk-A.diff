@@ -0,0 +1,147 @@
+import type {
+  BudgetConstraint,
+  IntentRecordInputDto,
+  PeriodConstraint,
+} from "@/shared/contracts/intent-record";
+import {
+  DISPOSAL_INTENT_TYPE_VALUES,
+  INTENT_TYPE_VALUES,
+  LIQUIDITY_NEED_VALUES,
+  TIME_PRESSURE_VALUES,
+} from "@/shared/contracts/intent-record";
+
+type ValidationSuccess = {
+  ok: true;
+  value: IntentRecordInputDto;
+};
+
+type ValidationFailure = {
+  ok: false;
+  code: "INVALID_INPUT" | "INVALID_CONSTRAINT";
+  message: string;
+  details?: Record<string, unknown>;
+};
+
+export type IntentRecordValidationResult = ValidationSuccess | ValidationFailure;
+
+function isEnumValue<T extends readonly string[]>(value: unknown, values: T): value is T[number] {
+  return typeof value === "string" && values.includes(value);
+}
+
+function isBudgetConstraint(value: unknown): value is BudgetConstraint {
+  if (typeof value !== "object" || value === null) {
+    return false;
+  }
+
+  const candidate = value as Partial<BudgetConstraint>;
+  return (
+    typeof candidate.min === "number" &&
+    typeof candidate.max === "number" &&
+    Number.isFinite(candidate.min) &&
+    Number.isFinite(candidate.max) &&
+    typeof candidate.currency === "string" &&
+    candidate.currency.trim().length > 0
+  );
+}
+
+function isPeriodConstraint(value: unknown): value is PeriodConstraint {
+  if (typeof value !== "object" || value === null) {
+    return false;
+  }
+
+  const candidate = value as Partial<PeriodConstraint>;
+  return typeof candidate.startAt === "string" && typeof candidate.endAt === "string";
+}
+
+export function validateIntentRecordInput(input: unknown): IntentRecordValidationResult {
+  if (typeof input !== "object" || input === null) {
+    return {
+      ok: false,
+      code: "INVALID_INPUT",
+      message: "의향 입력 본문은 객체여야 합니다.",
+    };
+  }
+
+  const candidate = input as Partial<IntentRecordInputDto>;
+  if (
+    typeof candidate.assetId !== "string" ||
+    candidate.assetId.trim().length === 0 ||
+    !isEnumValue(candidate.intentType, INTENT_TYPE_VALUES) ||
+    !isEnumValue(candidate.disposalIntentType, DISPOSAL_INTENT_TYPE_VALUES) ||
+    !isEnumValue(candidate.timePressure, TIME_PRESSURE_VALUES) ||
+    !isEnumValue(candidate.liquidityNeed, LIQUIDITY_NEED_VALUES) ||
+    !isBudgetConstraint(candidate.budgetConstraint) ||
+    !isPeriodConstraint(candidate.periodConstraint) ||
+    typeof candidate.isPublicIntent !== "boolean" ||
+    typeof candidate.changeReasonSummary !== "string" ||
+    candidate.changeReasonSummary.trim().length === 0
+  ) {
+    return {
+      ok: false,
+      code: "INVALID_INPUT",
+      message: "필수 입력값이 누락되었거나 형식이 올바르지 않습니다.",
+      details: {
+        required: [
+          "assetId",
+          "intentType",
+          "disposalIntentType",
+          "timePressure",
+          "liquidityNeed",
+          "budgetConstraint",
+          "periodConstraint",
+          "isPublicIntent",
+          "changeReasonSummary",
+        ],
+      },
+    };
+  }
+
+  if (candidate.budgetConstraint.min < 0 || candidate.budgetConstraint.max < 0) {
+    return {
+      ok: false,
+      code: "INVALID_CONSTRAINT",
+      message: "예산 범위는 0 이상이어야 합니다.",
+    };
+  }
+
+  if (candidate.budgetConstraint.min > candidate.budgetConstraint.max) {
+    return {
+      ok: false,
+      code: "INVALID_CONSTRAINT",
+      message: "budgetConstraint.min은 max보다 클 수 없습니다.",
+    };
+  }
+
+  const startAt = Date.parse(candidate.periodConstraint.startAt);
+  const endAt = Date.parse(candidate.periodConstraint.endAt);
+  if (Number.isNaN(startAt) || Number.isNaN(endAt)) {
+    return {
+      ok: false,
+      code: "INVALID_CONSTRAINT",
+      message: "periodConstraint는 ISO-8601 UTC 시각이어야 합니다.",
+    };
+  }
+
+  if (startAt > endAt) {
+    return {
+      ok: false,
+      code: "INVALID_CONSTRAINT",
+      message: "periodConstraint.startAt은 endAt보다 늦을 수 없습니다.",
+    };
+  }
+
+  const validated = candidate as IntentRecordInputDto;
+
+  return {
+    ok: true,
+    value: {
+      ...validated,
+      assetId: validated.assetId.trim(),
+      changeReasonSummary: validated.changeReasonSummary.trim(),
+      budgetConstraint: {
+        ...validated.budgetConstraint,
+        currency: validated.budgetConstraint.currency.trim().toUpperCase(),
+      },
+    },
+  };
+}

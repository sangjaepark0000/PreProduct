@@ -0,0 +1,137 @@
+import { NextResponse } from "next/server";
+import type { ApiError, ApiSuccess } from "@/shared/contracts/api-response";
+import {
+  INTENT_RECORD_EVENT_MAP,
+  type IntentRecordRequestDto,
+  type IntentRecordResponseDto,
+} from "@/shared/contracts/intent-record";
+import { mapIntentRecordRequest } from "@/infra/mapper/intent-record-mapper";
+import { validateIntentRecordInput } from "@/domain/intent/intent-record-validator";
+import {
+  getIntentRecordReplay,
+  rememberIntentRecordReplay,
+  upsertIntentRecord,
+} from "@/domain/intent/intent-record-service";
+import { recordIntentEvent } from "@/domain/intent/intent-event-log";
+
+type IntentRecordApiData = IntentRecordResponseDto;
+
+function buildError(
+  requestId: string,
+  code: string,
+  message: string,
+  details?: Record<string, unknown>,
+): ApiError {
+  return {
+    error: {
+      code,
+      message,
+      details,
+      requestId,
+    },
+  };
+}
+
+export async function POST(request: Request) {
+  const requestId = crypto.randomUUID();
+  const traceId = request.headers.get("x-trace-id") ?? requestId;
+  const idempotencyKey = request.headers.get("x-idempotency-key") ?? "";
+
+  let body: unknown;
+  try {
+    body = await request.json();
+  } catch {
+    return NextResponse.json(
+      buildError(requestId, "INVALID_JSON", "JSON 본문을 파싱할 수 없습니다.", { traceId }),
+      { status: 400 },
+    );
+  }
+
+  const payload = mapIntentRecordRequest(body) as Partial<IntentRecordRequestDto>;
+  const validation = validateIntentRecordInput(payload.input);
+  if (!validation.ok) {
+    return NextResponse.json(
+      buildError(requestId, validation.code, validation.message, {
+        traceId,
+        ...validation.details,
+      }),
+      { status: 400 },
+    );
+  }
+
+  if (idempotencyKey) {
+    const replay = getIntentRecordReplay(idempotencyKey);
+    if (replay) {
+      return NextResponse.json(
+        {
+          data: replay,
+          meta: {
+            requestId,
+            traceId,
+            idempotentReplay: true,
+            event: {
+              name: "intent.record.saved.v1",
+              canonical: INTENT_RECORD_EVENT_MAP["intent.record.saved.v1"],
+            },
+          },
+        } satisfies ApiSuccess<IntentRecordApiData>,
+        { status: 200 },
+      );
+    }
+  }
+
+  const startEvent = recordIntentEvent(
+    "intent.record.input_started.v1",
+    INTENT_RECORD_EVENT_MAP["intent.record.input_started.v1"],
+    traceId,
+    `${validation.value.assetId}:${idempotencyKey || traceId}`,
+  );
+  if (startEvent.duplicated) {
+    console.warn("[intent-event] duplicate start_intent_input", {
+      traceId,
+      assetId: validation.value.assetId,
+    });
+  }
+
+  const intentRecord = upsertIntentRecord(validation.value, new Date().toISOString());
+
+  const completeEvent = recordIntentEvent(
+    "intent.record.saved.v1",
+    INTENT_RECORD_EVENT_MAP["intent.record.saved.v1"],
+    traceId,
+    idempotencyKey || `${intentRecord.intentId}:${intentRecord.version}`,
+  );
+  if (completeEvent.duplicated) {
+    console.warn("[intent-event] duplicate complete_intent_input", {
+      traceId,
+      intentId: intentRecord.intentId,
+    });
+  }
+
+  const responseData: IntentRecordResponseDto = {
+    intentRecord,
+  };
+
+  if (idempotencyKey) {
+    rememberIntentRecordReplay(idempotencyKey, responseData);
+  }
+
+  return NextResponse.json(
+    {
+      data: responseData,
+      meta: {
+        requestId,
+        traceId,
+        idempotentReplay: false,
+        event: {
+          ...completeEvent.envelope,
+        },
+        warnings: [
+          ...(startEvent.duplicated ? ["DUPLICATE_START_EVENT"] : []),
+          ...(completeEvent.duplicated ? ["DUPLICATE_COMPLETE_EVENT"] : []),
+        ],
+      },
+    } satisfies ApiSuccess<IntentRecordApiData>,
+    { status: 200 },
+  );
+}

diff --git a/src/domain/intent/idempotency-key-lock.ts b/src/domain/intent/idempotency-key-lock.ts
new file mode 100644
--- /dev/null
+++ b/src/domain/intent/idempotency-key-lock.ts
@@ -0,0 +1,27 @@
+const lockTails = new Map<string, Promise<void>>();
+
+export async function runWithIdempotencyKeyLock<T>(
+  namespace: string,
+  idempotencyKey: string,
+  task: () => Promise<T>,
+): Promise<T> {
+  const lockKey = `${namespace}:${idempotencyKey}`;
+  const previousTail = lockTails.get(lockKey) ?? Promise.resolve();
+
+  let releaseCurrent!: () => void;
+  const currentTail = new Promise<void>((resolve) => {
+    releaseCurrent = resolve;
+  });
+  const mergedTail = previousTail.then(() => currentTail);
+  lockTails.set(lockKey, mergedTail);
+
+  await previousTail;
+  try {
+    return await task();
+  } finally {
+    releaseCurrent();
+    if (lockTails.get(lockKey) === mergedTail) {
+      lockTails.delete(lockKey);
+    }
+  }
+}

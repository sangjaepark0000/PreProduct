+++ b/src/infra/mapper/listing-draft-mapper.ts
@@ -0,0 +1,37 @@
+import type {
+  ListingDraftDto,
+  ListingDraftInputDto,
+  ListingDraftRequestDto,
+} from "@/shared/contracts/listing-draft";
+import type { ListingDraftDomainModel } from "@/domain/listing/listing-draft-service";
+import { mapTopLevelKeysSnakeToCamel } from "@/infra/mapper/case-mapper";
+
+export function mapListingDraftRequest(body: unknown): Partial<ListingDraftRequestDto> {
+  if (typeof body !== "object" || body === null) {
+    return {};
+  }
+
+  const mapped = mapTopLevelKeysSnakeToCamel(body as Record<string, unknown>);
+  const input = mapped.input;
+  if (typeof input !== "object" || input === null) {
+    return mapped as Partial<ListingDraftRequestDto>;
+  }
+
+  const mappedInput = mapTopLevelKeysSnakeToCamel(input as Record<string, unknown>);
+  return {
+    ...mapped,
+    input: mappedInput as Partial<ListingDraftInputDto>,
+  } as Partial<ListingDraftRequestDto>;
+}
+
+export function mapListingDraftDomainToDto(model: ListingDraftDomainModel): ListingDraftDto {
+  return {
+    draftId: model.draft_id,
+    title: model.title,
+    category: model.category,
+    keySpecs: model.key_specs,
+    price: model.price,
+    ownerId: model.owner_id,
+    createdAt: model.created_at,
+  };
+}
diff --git a/src/app/api/listings/drafts/route.ts b/src/app/api/listings/drafts/route.ts
new file mode 100644
index 0000000..e42ff3f
--- /dev/null
+++ b/src/app/api/listings/drafts/route.ts
@@ -0,0 +1,103 @@
+import { NextResponse } from "next/server";
+import type { ApiError, ApiSuccess } from "@/shared/contracts/api-response";
+import type { ListingDraftResponseDto } from "@/shared/contracts/listing-draft";
+import { mapListingDraftDomainToDto, mapListingDraftRequest } from "@/infra/mapper/listing-draft-mapper";
+import { validateListingDraftInput } from "@/domain/listing/listing-draft-validator";
+import { createListingDraft } from "@/domain/listing/listing-draft-service";
+
+type ListingDraftApiData = ListingDraftResponseDto;
+
+function buildError(
+  requestId: string,
+  code: string,
+  message: string,
+  details?: Record<string, unknown>,
+): ApiError {
+  return {
+    error: {
+      code,
+      message,
+      details,
+      requestId,
+    },
+  };
+}
+
+export async function POST(request: Request) {
+  const requestId = crypto.randomUUID();
+  const traceId = request.headers.get("x-trace-id") ?? requestId;
+  const shouldSimulateBootstrapFailure =
+    request.headers.get("x-preproduct-simulate-bootstrap-failure") === "true";
+
+  if (shouldSimulateBootstrapFailure) {
+    return NextResponse.json(
+      buildError(
+        requestId,
+        "BOOTSTRAP_VALIDATION_FAILED",
+        "부팅 또는 기본 검증 단계가 실패했습니다.",
+        {
+          traceId,
+          recoveryGuide: "복구 절차를 확인한 뒤 동일 화면에서 재시도하세요.",
+          recoverySteps: [
+            "네트워크 연결 상태를 점검하세요.",
+            "입력값을 유지한 채 동일 화면에서 다시 시도하세요.",
+          ],
+          retryAction: "same_screen_retry",
+        },
+      ),
+      { status: 503 },
+    );
+  }
+
+  let body: unknown;
+  try {
+    body = await request.json();
+  } catch {
+    return NextResponse.json(
+      buildError(requestId, "INVALID_JSON", "JSON 본문을 파싱할 수 없습니다.", {
+        traceId,
+        recoveryGuide: "JSON 형식을 확인한 뒤 다시 시도하세요.",
+      }),
+      { status: 400 },
+    );
+  }
+
+  let payload;
+  try {
+    payload = mapListingDraftRequest(body);
+  } catch {
+    return NextResponse.json(
+      buildError(requestId, "INVALID_INPUT", "요청 필드명이 충돌하여 처리할 수 없습니다.", {
+        traceId,
+        recoveryGuide: "input 필드명을 확인한 뒤 다시 시도하세요.",
+      }),
+      { status: 400 },
+    );
+  }
+
+  const validation = validateListingDraftInput(payload.input);
+  if (!validation.ok) {
+    return NextResponse.json(
+      buildError(requestId, validation.code, validation.message, {
+        traceId,
+        ...validation.details,
+      }),
+      { status: 400 },
+    );
+  }
+
+  const listingDraft = createListingDraft(validation.value, new Date().toISOString());
+
+  return NextResponse.json(
+    {
+      data: {
+        listingDraft: mapListingDraftDomainToDto(listingDraft),
+      },
+      meta: {
+        requestId,
+        traceId,
+      },
+    } satisfies ApiSuccess<ListingDraftApiData>,
+    { status: 200 },
+  );
+}
diff --git a/src/feature/listing/components/listing-draft-form.tsx b/src/feature/listing/components/listing-draft-form.tsx
new file mode 100644
index 0000000..9a4d94e
--- /dev/null
+++ b/src/feature/listing/components/listing-draft-form.tsx
@@ -0,0 +1,255 @@
+"use client";
+
+import { useRef, useState } from "react";
+import styles from "./listing-draft-form.module.css";
+
+type ListingDraftFormState = {
+  title: string;
+  category: string;
+  keySpecsText: string;
+  price: string;
+  ownerId: string;
+};
+
+type ListingDraftRequestInput = {
+  title: string;
+  category: string;
+  keySpecs: string[];
+  price: number;
+  ownerId: string;
+};
+
+type ListingDraftApiPayload = {
+  data: {
+    listingDraft: {
+      draftId: string;
+      createdAt: string;
+    };
+  };
+};
+
+type ListingDraftApiError = {
+  error: {
+    message: string;
+    details?: {
+      recoveryGuide?: string;
+      recoverySteps?: string[];
+      retryAction?: string;
+    };
+  };
+};
+
+const INITIAL_FORM: ListingDraftFormState = {
+  title: "한강뷰 아파트",
+  category: "apartment",
+  keySpecsText: "전용84, 남향",
+  price: "1250000000",
+  ownerId: "owner_seed_001",
+};
+
+export function ListingDraftForm() {
+  const [form, setForm] = useState<ListingDraftFormState>(INITIAL_FORM);
+  const [isSubmitting, setIsSubmitting] = useState(false);
+  const [shouldShowRetry, setShouldShowRetry] = useState(false);
+  const [statusText, setStatusText] = useState("아직 임시저장 전");
+  const [recoveryGuide, setRecoveryGuide] = useState("-");
+  const [recoverySteps, setRecoverySteps] = useState<string[]>([]);
+  const [draftInfo, setDraftInfo] = useState({ draftId: "-", createdAt: "-" });
+  const lastRequestRef = useRef<ListingDraftRequestInput | null>(null);
+  const submitLockRef = useRef(false);
+  const [simulateBootstrapFailure, setSimulateBootstrapFailure] = useState(false);
+
+  function updateField<K extends keyof ListingDraftFormState>(field: K, value: ListingDraftFormState[K]) {
+    setForm((prev) => ({ ...prev, [field]: value }));
+  }
+
+  function buildInput(): ListingDraftRequestInput {
+    return {
+      title: form.title,
+      category: form.category,
+      keySpecs: form.keySpecsText
+        .split(",")
+        .map((value) => value.trim())
+        .filter((value) => value.length > 0),
+      price: Number(form.price),
+      ownerId: form.ownerId,
+    };
+  }
+
+  async function submit(input: ListingDraftRequestInput, options?: { simulateFailure?: boolean }) {
+    const simulateFailure = options?.simulateFailure === true;
+    const response = await fetch("/api/listings/drafts", {
+      method: "POST",
+      headers: {
+        "content-type": "application/json",
+        ...(simulateFailure ? { "x-preproduct-simulate-bootstrap-failure": "true" } : {}),
+      },
+      body: JSON.stringify({ input }),
+    });
+
+    if (!response.ok) {
+      const payload = (await response.json()) as ListingDraftApiError;
+      const details = payload.error.details;
+      setStatusText(`임시저장 실패: ${payload.error.message}`);
+      setRecoveryGuide(details?.recoveryGuide ?? "입력값을 점검한 뒤 다시 시도하세요.");
+      setRecoverySteps(details?.recoverySteps ?? []);
+      setShouldShowRetry(details?.retryAction === "same_screen_retry");
+      return;
+    }
+
+    const payload = (await response.json()) as ListingDraftApiPayload;
+    setStatusText("임시저장 완료");
+    setDraftInfo({
+      draftId: payload.data.listingDraft.draftId,
+      createdAt: payload.data.listingDraft.createdAt,
+    });
+    setRecoveryGuide("-");
+    setRecoverySteps([]);
+    setShouldShowRetry(false);
+  }
+
+  async function handleSubmit(event: React.FormEvent<HTMLFormElement>) {
+    event.preventDefault();
+    if (submitLockRef.current) {
+      return;
+    }
+    submitLockRef.current = true;
+    setIsSubmitting(true);
+    setStatusText("임시저장 중");
+    try {
+      const input = buildInput();
+      lastRequestRef.current = input;
+      await submit(input, { simulateFailure: simulateBootstrapFailure });
+    } catch {
+      setStatusText("임시저장 실패: 네트워크 오류");
+      setRecoveryGuide("네트워크 상태를 확인하고 동일 화면에서 다시 시도하세요.");
+      setRecoverySteps(["입력값은 유지됩니다.", "다시 시도 버튼을 눌러 재요청하세요."]);
+      setShouldShowRetry(true);
+    } finally {
+      submitLockRef.current = false;
+      setIsSubmitting(false);
+    }
+  }
+
+  async function handleRetry() {
+    if (!lastRequestRef.current || submitLockRef.current) {
+      return;
+    }
+    submitLockRef.current = true;
+    setIsSubmitting(true);
+    setStatusText("재시도 중");
+    try {
+      setSimulateBootstrapFailure(false);
+      await submit(lastRequestRef.current, { simulateFailure: false });
+    } catch {
+      setStatusText("재시도 실패: 네트워크 오류");
+      setRecoveryGuide("잠시 후 동일 화면에서 다시 시도하세요.");
+    } finally {
+      submitLockRef.current = false;
+      setIsSubmitting(false);
+    }
+  }
+
+  return (
+    <section className={styles.container} aria-label="프리리스팅 임시저장 섹션">
+      <form className={styles.form} onSubmit={handleSubmit}>
+        <h2>프리리스팅 시작</h2>
+
+        <label className={styles.fieldLabel} htmlFor="listing-title">
+          제목
+        </label>
+        <input
+          id="listing-title"
+          className={styles.textField}
+          value={form.title}
+          onChange={(event) => updateField("title", event.target.value)}
+          required
+        />
+
+        <label className={styles.fieldLabel} htmlFor="listing-category">
+          카테고리
+        </label>
+        <input
+          id="listing-category"
+          className={styles.textField}
+          value={form.category}
+          onChange={(event) => updateField("category", event.target.value)}
+          required
+        />
+
+        <label className={styles.fieldLabel} htmlFor="listing-key-specs">
+          핵심 스펙
+        </label>
+        <input
+          id="listing-key-specs"
+          className={styles.textField}
+          value={form.keySpecsText}
+          onChange={(event) => updateField("keySpecsText", event.target.value)}
+          required
+        />
+
+        <label className={styles.fieldLabel} htmlFor="listing-price">
+          가격
+        </label>
+        <input
+          id="listing-price"
+          className={styles.textField}
+          type="number"
+          min={1}
+          value={form.price}
+          onChange={(event) => updateField("price", event.target.value)}
+          required
+        />
+
+        <label className={styles.fieldLabel} htmlFor="listing-owner-id">
+          소유자 ID
+        </label>
+        <input
+          id="listing-owner-id"
+          className={styles.textField}
+          value={form.ownerId}
+          onChange={(event) => updateField("ownerId", event.target.value)}
+          required
+        />
+
+        <label className={styles.fieldLabel} htmlFor="simulate-bootstrap-failure">
+          <input
+            id="simulate-bootstrap-failure"
+            type="checkbox"
+            checked={simulateBootstrapFailure}
+            onChange={(event) => setSimulateBootstrapFailure(event.target.checked)}
+          />{" "}
+          부팅 검증 실패 시뮬레이션(테스트)
+        </label>
+
+        <p className={styles.hint}>핵심 스펙은 쉼표로 구분해 1개 이상 입력하세요.</p>
+
+        <div className={styles.actions}>
+          <button className={styles.saveButton} type="submit" disabled={isSubmitting}>
+            {isSubmitting ? "처리 중..." : "임시저장"}
+          </button>
+          {shouldShowRetry ? (
+            <button
+              className={styles.retryButton}
+              type="button"
+              disabled={isSubmitting}
+              onClick={handleRetry}
+            >
+              동일 화면에서 다시 시도
+            </button>
+          ) : null}
+        </div>
+      </form>
+
+      <div className={styles.statusBox} role="status" aria-live="polite">
+        <p className={styles.statusText}>{statusText}</p>
+        <p>복구 가이드: {recoveryGuide}</p>
+        {recoverySteps.map((step, index) => (
+          <p key={`recovery-step-${index + 1}`}>{`${index + 1}. ${step}`}</p>
+        ))}
+        <p>draftId: {draftInfo.draftId}</p>
+        <p>createdAt: {draftInfo.createdAt}</p>
+      </div>
+    </section>
+  );
+}

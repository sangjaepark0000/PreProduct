+import { expect, test } from "@playwright/test";
+
+function buildValidInput() {
+  return {
+    title: "서울 강남 역세권 오피스텔",
+    category: "officetel",
+    keySpecs: ["전용 29", "역 도보 5분"],
+    price: 720000000,
+    ownerId: `owner_contract_${crypto.randomUUID()}`,
+  };
+}
+
+test.describe("프리리스팅 임시저장 API 계약", () => {
+  test("정상 저장: data/meta 계약과 draft 식별자를 반환한다", async ({ request }) => {
+    const response = await request.post("/api/listings/drafts", {
+      data: {
+        input: buildValidInput(),
+      },
+    });
+
+    expect(response.status()).toBe(200);
+    const payload = (await response.json()) as {
+      data: {
+        listingDraft: {
+          draftId: string;
+          ownerId: string;
+          title: string;
+          category: string;
+          keySpecs: string[];
+          price: number;
+          createdAt: string;
+        };
+      };
+      meta: {
+        requestId: string;
+        traceId: string;
+      };
+    };
+
+    expect(payload.data.listingDraft.draftId).toMatch(/^draft_/);
+    expect(payload.data.listingDraft.ownerId).toMatch(/^owner_contract_/);
+    expect(payload.data.listingDraft.keySpecs.length).toBeGreaterThan(0);
+    expect(payload.data.listingDraft.price).toBeGreaterThan(0);
+    expect(Number.isNaN(Date.parse(payload.data.listingDraft.createdAt))).toBeFalsy();
+    expect(typeof payload.meta.requestId).toBe("string");
+    expect(typeof payload.meta.traceId).toBe("string");
+  });
+
+  test("검증 실패: 필수 필드가 비면 400 + 복구 가이드 계약을 반환한다", async ({ request }) => {
+    const response = await request.post("/api/listings/drafts", {
+      data: {
+        input: {
+          ...buildValidInput(),
+          title: "",
+          keySpecs: [],
+          price: 0,
+        },
+      },
+    });
+
+    expect(response.status()).toBe(400);
+    const payload = await response.json();
+    expect(payload.error.code).toBe("INVALID_INPUT");
+    expect(payload.error.details.retryAction).toBe("same_screen_retry");
+    expect(Array.isArray(payload.error.details.recoverySteps)).toBeTruthy();
+    expect(payload.error.details.recoverySteps.length).toBeGreaterThan(0);
+  });
+
+  test("부팅 검증 실패: 503 + 동일 화면 재시도 안내를 반환한다", async ({ request }) => {
+    const response = await request.post("/api/listings/drafts", {
+      headers: {
+        "x-preproduct-simulate-bootstrap-failure": "true",
+      },
+      data: {
+        input: buildValidInput(),
+      },
+    });
+
+    expect(response.status()).toBe(503);
+    const payload = await response.json();
+    expect(payload.error.code).toBe("BOOTSTRAP_VALIDATION_FAILED");
+    expect(payload.error.details.retryAction).toBe("same_screen_retry");
+    expect(payload.error.details.recoveryGuide).toContain("동일 화면");
+  });
+
+  test("복구 후 재시도: 실패 이후 동일 입력으로 즉시 저장이 가능하다", async ({ request }) => {
+    const input = buildValidInput();
+    const failed = await request.post("/api/listings/drafts", {
+      headers: {
+        "x-preproduct-simulate-bootstrap-failure": "true",
+      },
+      data: {
+        input,
+      },
+    });
+    expect(failed.status()).toBe(503);
+
+    const recovered = await request.post("/api/listings/drafts", {
+      data: {
+        input,
+      },
+    });
+    expect(recovered.status()).toBe(200);
+    const payload = await recovered.json();
+    expect(payload.data.listingDraft.draftId).toMatch(/^draft_/);
+  });
+
+  test("회귀: 기존 intents/intents-records/decision-cards 계약은 유지된다", async ({ request }) => {
+    const intentDiagnostic = await request.post("/api/intents", {
+      data: {
+        input: {
+          goalClarity: "medium",
+          productClarity: "medium",
+          timePressure: "high",
+          liquidityNeed: "low",
+        },
+        uiEventAlias: "state_assessed",
+      },
+    });
+    expect(intentDiagnostic.status()).toBe(200);
+
+    const intentRecord = await request.post("/api/intents/records", {
+      data: {
+        input: {
+          assetId: `asset_listing_reg_${crypto.randomUUID()}`,
+          intentType: "buy",
+          disposalIntentType: "upgrade",
+          timePressure: "medium",
+          liquidityNeed: "low",
+          budgetConstraint: {
+            min: 0,
+            max: 10000000,
+            currency: "KRW",
+          },
+          periodConstraint: {
+            startAt: "2026-04-06T00:00:00.000Z",
+            endAt: "2026-05-06T00:00:00.000Z",
+          },
+          isPublicIntent: true,
+          changeReasonSummary: "listing story regression check",
+        },
+      },
+    });
+    expect(intentRecord.status()).toBe(200);
+
+    const decisionCard = await request.post("/api/decision-cards", {
+      data: {
+        input: {
+          assetId: `asset_listing_decision_${crypto.randomUUID()}`,
+          timePressure: "medium",
+          liquidityNeed: "low",
+        },
+      },
+    });
+    expect(decisionCard.status()).toBe(200);
+  });
+});

@@ -0,0 +1,28 @@
+import type { ListingDraftInputDto } from "@/shared/contracts/listing-draft";
+
+export type ListingDraftDomainModel = {
+  draft_id: string;
+  title: string;
+  category: string;
+  key_specs: string[];
+  price: number;
+  owner_id: string;
+  created_at: string;
+};
+
+const listingDraftStore: Record<string, ListingDraftDomainModel> = {};
+
+export function createListingDraft(input: ListingDraftInputDto, nowIso: string): ListingDraftDomainModel {
+  const draft: ListingDraftDomainModel = {
+    draft_id: `draft_${crypto.randomUUID()}`,
+    title: input.title,
+    category: input.category,
+    key_specs: [...input.keySpecs],
+    price: input.price,
+    owner_id: input.ownerId,
+    created_at: nowIso,
+  };
+
+  listingDraftStore[draft.draft_id] = draft;
+  return draft;
+}

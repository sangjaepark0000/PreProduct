@@ -0,0 +1,81 @@
+import type { ListingDraftInputDto } from "@/shared/contracts/listing-draft";
+
+type ValidationSuccess = {
+  ok: true;
+  value: ListingDraftInputDto;
+};
+
+type ValidationFailure = {
+  ok: false;
+  code: "INVALID_INPUT";
+  message: string;
+  details: {
+    requiredFields: string[];
+    recoveryGuide: string;
+    recoverySteps: string[];
+    retryAction: "same_screen_retry";
+  };
+};
+
+export type ListingDraftValidationResult = ValidationSuccess | ValidationFailure;
+
+export function validateListingDraftInput(input: unknown): ListingDraftValidationResult {
+  if (typeof input !== "object" || input === null) {
+    return buildInvalidInputResult();
+  }
+
+  const candidate = input as Partial<ListingDraftInputDto>;
+  const keySpecsCandidate = Array.isArray(candidate.keySpecs)
+    ? candidate.keySpecs
+        .filter((value): value is string => typeof value === "string")
+        .map((value) => value.trim())
+        .filter((value) => value.length > 0)
+    : [];
+
+  const title = typeof candidate.title === "string" ? candidate.title.trim() : "";
+  const category = typeof candidate.category === "string" ? candidate.category.trim() : "";
+  const ownerId = typeof candidate.ownerId === "string" ? candidate.ownerId.trim() : "";
+  const price = candidate.price;
+
+  if (
+    title.length === 0 ||
+    category.length === 0 ||
+    keySpecsCandidate.length === 0 ||
+    typeof price !== "number" ||
+    !Number.isFinite(price) ||
+    price <= 0 ||
+    ownerId.length === 0
+  ) {
+    return buildInvalidInputResult();
+  }
+
+  return {
+    ok: true,
+    value: {
+      title,
+      category,
+      keySpecs: keySpecsCandidate,
+      price,
+      ownerId,
+    },
+  };
+}
+
+function buildInvalidInputResult(): ValidationFailure {
+  return {
+    ok: false,
+    code: "INVALID_INPUT",
+    message: "필수 필드가 누락되었거나 형식이 올바르지 않습니다.",
+    details: {
+      requiredFields: ["title", "category", "keySpecs(1+)", "price", "ownerId"],
+      recoveryGuide: "제목/카테고리/핵심 스펙/가격/소유자 ID를 확인한 뒤 다시 시도하세요.",
+      recoverySteps: [
+        "제목과 카테고리를 입력하세요.",
+        "핵심 스펙을 1개 이상 입력하세요.",
+        "가격은 0보다 큰 숫자로 입력하세요.",
+        "소유자 ID를 확인한 뒤 동일 화면에서 다시 시도하세요.",
+      ],
+      retryAction: "same_screen_retry",
+    },
+  };
+}

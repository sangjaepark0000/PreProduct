diff --git a/src/app/api/decision-cards/route.ts b/src/app/api/decision-cards/route.ts new file mode 100644 index 0000000..cfe3886 --- /dev/null +++ b/src/app/api/decision-cards/route.ts @@ -0,0 +1,88 @@ +import { NextResponse } from "next/server"; +import type { ApiError, ApiSuccess } from "@/shared/contracts/api-response"; +import type { DecisionCardResponseDto } from "@/shared/contracts/decision-card"; +import { mapDecisionCardRequest, mapDecisionCardDomainToDto } from "@/infra/mapper/decision-card-mapper"; +import { validateDecisionCardInput } from "@/domain/decision/decision-card-validator"; +import { createDecisionCard } from "@/domain/decision/decision-card-service"; + +type DecisionCardApiData = DecisionCardResponseDto; + +function buildError( +  requestId: string, +  code: string, +  message: string, +  details?: Record<string, unknown>, +): ApiError { +  return { +    error: { +      code, +      message, +      details, +      requestId, +    }, +  }; +} + +export async function POST(request: Request) { +  const requestId = crypto.randomUUID(); +  const traceId = request.headers.get("x-trace-id") ?? requestId; + +  let body: unknown; +  try { +    body = await request.json(); +  } catch { +    return NextResponse.json( +      buildError(requestId, "INVALID_JSON", "JSON 본문을 파싱할 수 없습니다.", { +        traceId, +        recoveryGuide: "JSON 형식을 확인한 뒤 다시 시도하세요.", +      }), +      { status: 400 }, +    ); +  } + +  let payload; +  try { +    payload = mapDecisionCardRequest(body); +  } catch { +    return NextResponse.json( +      buildError(requestId, "INVALID_INPUT", "요청 필드명이 충돌하여 처리할 수 없습니다.", { +        traceId, +        recoveryGuide: "assetId, timePressure, liquidityNeed를 확인 후 다시 시도하세요.", +      }), +      { status: 400 }, +    ); +  } + +  const validation = validateDecisionCardInput(payload.input); +  if (!validation.ok) { +    return NextResponse.json( +      buildError(requestId, validation.code, validation.message, { +        traceId, +        recoveryGuide: validation.recoveryGuide, +      }), +      { status: 400 }, +    ); +  } + +  const decisionResult = createDecisionCard({ +    ...validation.value, +    staleThresholdHours: validation.staleThresholdHours, +    traceId, +  }); + +  return NextResponse.json( +    { +      data: { +        decisionCard: mapDecisionCardDomainToDto(decisionResult.decisionCard), +      }, +      meta: { +        requestId, +        traceId, +        event: decisionResult.events[0], +        events: decisionResult.events, +        warnings: decisionResult.warnings, +      }, +    } satisfies ApiSuccess<DecisionCardApiData>, +    { status: 200 }, +  ); +}
diff --git a/src/domain/decision/decision-card-service.ts b/src/domain/decision/decision-card-service.ts new file mode 100644 index 0000000..9483a8d --- /dev/null +++ b/src/domain/decision/decision-card-service.ts @@ -0,0 +1,236 @@ +import type { +  DecisionAction, +  DecisionAssetState, +  DecisionLiquidityNeed, +  DecisionRiskLevel, +  DecisionTimePressure, +  DecisionTrustConfidence, +} from "@/shared/contracts/decision-card"; +import { recordDecisionEvent, type DecisionEventEnvelope } from "@/domain/decision/decision-event-log"; +import { withIntentSharedState } from "@/domain/intent/intent-shared-state"; + +type DecisionOptionModel = { +  action: DecisionAction; +  rationale_summary: string; +  confidence_score: number; +  risk_level: DecisionRiskLevel; +}; + +export type DecisionCardDomainModel = { +  options: DecisionOptionModel[]; +  intent_context: { +    trust_freshness_hours: number; +    trust_confidence: DecisionTrustConfidence; +  }; +  asset_transition: { +    current_state: DecisionAssetState; +    last_transition_at: string; +    version: number; +  }; +  fallback_applied: boolean; +}; + +export type DecisionCardDomainResult = { +  decisionCard: DecisionCardDomainModel; +  events: DecisionEventEnvelope[]; +  warnings: string[]; +}; + +type CreateDecisionCardInput = { +  assetId: string; +  timePressure: DecisionTimePressure; +  liquidityNeed: DecisionLiquidityNeed; +  trustFreshnessHours?: number; +  staleThresholdHours: number; +  traceId: string; +}; + +function roundConfidence(value: number): number { +  const clamped = Math.max(0, Math.min(1, value)); +  return Math.round(clamped * 100) / 100; +} + +function deriveRiskLevel(score: number): DecisionRiskLevel { +  if (score >= 0.7) { +    return "low"; +  } +  if (score >= 0.45) { +    return "medium"; +  } +  return "high"; +} + +function deriveTrustConfidence(trustFreshnessHours: number): DecisionTrustConfidence { +  if (trustFreshnessHours <= 24) { +    return "high"; +  } +  if (trustFreshnessHours <= 72) { +    return "medium"; +  } +  return "low"; +} + +function mapAssetState(intentType?: string, disposalIntentType?: string): DecisionAssetState { +  if (intentType === "sell") { +    return "selling"; +  } +  if (intentType === "buy") { +    return "owned"; +  } +  if (disposalIntentType === "liquidity") { +    return "leased"; +  } +  return "held"; +} + +function buildFallbackOptions(): DecisionOptionModel[] { +  return [ +    { +      action: "buy", +      rationale_summary: "의향 신선도가 낮아 즉시 매수 판단의 신뢰가 부족합니다.", +      confidence_score: 0.33, +      risk_level: "high", +    }, +    { +      action: "sell", +      rationale_summary: "보유 리스크를 즉시 확정하기보다 조건 확인이 우선입니다.", +      confidence_score: 0.31, +      risk_level: "high", +    }, +    { +      action: "hold", +      rationale_summary: "핵심 입력값 재확인 전까지 보류가 상대적으로 안전합니다.", +      confidence_score: 0.62, +      risk_level: "medium", +    }, +    { +      action: "alternative", +      rationale_summary: "알림 기반 재진입 조건을 먼저 설정해 판단을 유예하세요.", +      confidence_score: 0.68, +      risk_level: "low", +    }, +  ]; +} + +function buildBaseScore(timePressure: DecisionTimePressure, liquidityNeed: DecisionLiquidityNeed): number { +  const pressureWeight: Record<DecisionTimePressure, number> = { +    low: 0.12, +    medium: 0, +    high: -0.14, +  }; + +  const liquidityWeight: Record<DecisionLiquidityNeed, number> = { +    low: 0.1, +    medium: 0, +    high: -0.16, +  }; + +  return 0.62 + pressureWeight[timePressure] + liquidityWeight[liquidityNeed]; +} + +function buildNormalOptions( +  timePressure: DecisionTimePressure, +  liquidityNeed: DecisionLiquidityNeed, +): DecisionOptionModel[] { +  const baseScore = buildBaseScore(timePressure, liquidityNeed); +  const buyScore = roundConfidence(baseScore + 0.09); +  const sellScore = roundConfidence(baseScore - 0.11); +  const holdScore = roundConfidence(baseScore + 0.01); +  const alternativeScore = roundConfidence(baseScore - 0.03); + +  return [ +    { +      action: "buy", +      rationale_summary: "입력된 압박도와 유동성 조건에서 매수 타이밍이 유효합니다.", +      confidence_score: buyScore, +      risk_level: deriveRiskLevel(buyScore), +    }, +    { +      action: "sell", +      rationale_summary: "유동성/시간 압박에 따른 보유 비용 위험을 반영했습니다.", +      confidence_score: sellScore, +      risk_level: deriveRiskLevel(sellScore), +    }, +    { +      action: "hold", +      rationale_summary: "입력 대비 가역성을 확보하며 추가 신호를 관찰하는 선택입니다.", +      confidence_score: holdScore, +      risk_level: deriveRiskLevel(holdScore), +    }, +    { +      action: "alternative", +      rationale_summary: "조건부 재진입 또는 알림 중심 전략으로 손실 노출을 줄입니다.", +      confidence_score: alternativeScore, +      risk_level: deriveRiskLevel(alternativeScore), +    }, +  ]; +} + +function calculateTrustFreshnessHours(updatedAt?: string, overrideHours?: number): number { +  if (overrideHours !== undefined) { +    return Math.floor(overrideHours); +  } +  if (!updatedAt) { +    return 0; +  } + +  const updatedAtMs = Date.parse(updatedAt); +  if (Number.isNaN(updatedAtMs)) { +    return 0; +  } + +  const diffMs = Date.now() - updatedAtMs; +  return Math.max(0, Math.floor(diffMs / (1000 * 60 * 60))); +} + +export function createDecisionCard(input: CreateDecisionCardInput): DecisionCardDomainResult { +  const intentRecord = withIntentSharedState((state) => state.intentsByAsset[input.assetId]); +  const trustFreshnessHours = calculateTrustFreshnessHours( +    intentRecord?.updatedAt, +    input.trustFreshnessHours, +  ); +  const fallbackApplied = trustFreshnessHours > input.staleThresholdHours; +  const trustConfidence = deriveTrustConfidence(trustFreshnessHours); +  const nowIso = new Date().toISOString(); + +  const generatedEvent = recordDecisionEvent( +    "decision.card.generated.v1", +    input.traceId, +    `${input.assetId}:${intentRecord?.version ?? 0}:${fallbackApplied ? "fallback" : "normal"}`, +  ); + +  const events: DecisionEventEnvelope[] = [generatedEvent.envelope]; +  const warnings: string[] = generatedEvent.duplicated ? ["DUPLICATE_DECISION_EVENT"] : []; + +  if (fallbackApplied) { +    const errorEvent = recordDecisionEvent( +      "decision.card.error.v1", +      input.traceId, +      `${input.assetId}:${trustFreshnessHours}:${input.staleThresholdHours}`, +    ); +    events.push(errorEvent.envelope); +    if (errorEvent.duplicated) { +      warnings.push("DUPLICATE_DECISION_ERROR_EVENT"); +    } +  } + +  return { +    decisionCard: { +      options: fallbackApplied +        ? buildFallbackOptions() +        : buildNormalOptions(input.timePressure, input.liquidityNeed), +      intent_context: { +        trust_freshness_hours: trustFreshnessHours, +        trust_confidence: trustConfidence, +      }, +      asset_transition: { +        current_state: mapAssetState(intentRecord?.intentType, intentRecord?.disposalIntentType), +        last_transition_at: intentRecord?.updatedAt ?? nowIso, +        version: intentRecord?.version ?? 1, +      }, +      fallback_applied: fallbackApplied, +    }, +    events, +    warnings, +  }; +}
diff --git a/src/domain/decision/decision-card-validator.ts b/src/domain/decision/decision-card-validator.ts new file mode 100644 index 0000000..3da4e31 --- /dev/null +++ b/src/domain/decision/decision-card-validator.ts @@ -0,0 +1,82 @@ +import { +  DECISION_LIQUIDITY_NEED_VALUES, +  DECISION_TIME_PRESSURE_VALUES, +  type DecisionCardInputDto, +} from "@/shared/contracts/decision-card"; + +export const TRUST_FRESHNESS_STALE_HOURS_DEFAULT = 168; + +type ValidationSuccess = { +  ok: true; +  value: DecisionCardInputDto; +  staleThresholdHours: number; +}; + +type ValidationFailure = { +  ok: false; +  code: "INVALID_INPUT"; +  message: string; +  recoveryGuide: string; +}; + +export type DecisionCardValidationResult = ValidationSuccess | ValidationFailure; + +function isEnumValue<T extends readonly string[]>(value: unknown, values: T): value is T[number] { +  return typeof value === "string" && values.includes(value); +} + +function parseStaleThresholdHours(): number { +  const raw = process.env.TRUST_FRESHNESS_STALE_HOURS; +  if (!raw) { +    return TRUST_FRESHNESS_STALE_HOURS_DEFAULT; +  } + +  const parsed = Number(raw); +  if (!Number.isFinite(parsed) || parsed <= 0) { +    return TRUST_FRESHNESS_STALE_HOURS_DEFAULT; +  } + +  return Math.floor(parsed); +} + +export function validateDecisionCardInput(input: unknown): DecisionCardValidationResult { +  if (typeof input !== "object" || input === null) { +    return { +      ok: false, +      code: "INVALID_INPUT", +      message: "필수 필드가 누락되었거나 범위를 벗어났습니다.", +      recoveryGuide: "assetId, timePressure, liquidityNeed를 확인 후 다시 시도하세요.", +    }; +  } + +  const candidate = input as Partial<DecisionCardInputDto>; +  const trustFreshnessHours = +    candidate.trustFreshnessHours === undefined ? undefined : Number(candidate.trustFreshnessHours); + +  if ( +    typeof candidate.assetId !== "string" || +    candidate.assetId.trim().length === 0 || +    !isEnumValue(candidate.timePressure, DECISION_TIME_PRESSURE_VALUES) || +    !isEnumValue(candidate.liquidityNeed, DECISION_LIQUIDITY_NEED_VALUES) || +    (trustFreshnessHours !== undefined && +      (!Number.isFinite(trustFreshnessHours) || trustFreshnessHours < 0)) +  ) { +    return { +      ok: false, +      code: "INVALID_INPUT", +      message: "필수 필드가 누락되었거나 범위를 벗어났습니다.", +      recoveryGuide: "assetId, timePressure, liquidityNeed를 확인 후 다시 시도하세요.", +    }; +  } + +  return { +    ok: true, +    value: { +      assetId: candidate.assetId.trim(), +      timePressure: candidate.timePressure, +      liquidityNeed: candidate.liquidityNeed, +      ...(trustFreshnessHours === undefined ? {} : { trustFreshnessHours }), +    }, +    staleThresholdHours: parseStaleThresholdHours(), +  }; +}
diff --git a/src/domain/decision/decision-event-log.ts b/src/domain/decision/decision-event-log.ts new file mode 100644 index 0000000..187f1cf --- /dev/null +++ b/src/domain/decision/decision-event-log.ts @@ -0,0 +1,70 @@ +import { +  DECISION_EVENT_NAME_TO_CANONICAL, +  type DecisionEventCanonical, +  type DecisionEventName, +} from "@/shared/contracts/decision-card"; +import { withIntentSharedState } from "@/domain/intent/intent-shared-state"; + +export type DecisionEventEnvelope = { +  eventId: string; +  eventName: DecisionEventName; +  canonical: DecisionEventCanonical; +  occurredAt: string; +  traceId: string; +  schemaVersion: number; +}; + +const DEDUPE_TTL_MS = 1000 * 60 * 60 * 24; +const DEDUPE_MAX_SIZE = 20000; + +function pruneDedupe(eventDedupeByToken: Record<string, number>, nowMs: number) { +  for (const [token, createdAtMs] of Object.entries(eventDedupeByToken)) { +    if (nowMs - createdAtMs > DEDUPE_TTL_MS) { +      delete eventDedupeByToken[token]; +    } +  } +} + +function enforceDedupeSize(eventDedupeByToken: Record<string, number>) { +  const entries = Object.entries(eventDedupeByToken); +  if (entries.length <= DEDUPE_MAX_SIZE) { +    return; +  } + +  entries +    .sort(([, a], [, b]) => a - b) +    .slice(0, entries.length - DEDUPE_MAX_SIZE) +    .forEach(([token]) => { +      delete eventDedupeByToken[token]; +    }); +} + +export function recordDecisionEvent( +  eventName: DecisionEventName, +  traceId: string, +  dedupeKey: string, +): { envelope: DecisionEventEnvelope; duplicated: boolean } { +  const dedupeToken = `${eventName}:${dedupeKey}`; +  const duplicated = withIntentSharedState((state) => { +    const nowMs = Date.now(); +    pruneDedupe(state.eventDedupeByToken, nowMs); +    const isDuplicated = dedupeToken in state.eventDedupeByToken; +    if (!isDuplicated) { +      state.eventDedupeByToken[dedupeToken] = nowMs; +      enforceDedupeSize(state.eventDedupeByToken); +    } +    return isDuplicated; +  }); + +  return { +    duplicated, +    envelope: { +      eventId: `evt_${crypto.randomUUID()}`, +      eventName, +      canonical: DECISION_EVENT_NAME_TO_CANONICAL[eventName], +      occurredAt: new Date().toISOString(), +      traceId, +      schemaVersion: 1, +    }, +  }; +}
diff --git a/src/domain/intent/idempotency-key-lock.ts b/src/domain/intent/idempotency-key-lock.ts new file mode 100644 index 0000000..d6fc904 --- /dev/null +++ b/src/domain/intent/idempotency-key-lock.ts @@ -0,0 +1,27 @@ +const lockTails = new Map<string, Promise<void>>(); + +export async function runWithIdempotencyKeyLock<T>( +  namespace: string, +  idempotencyKey: string, +  task: () => Promise<T>, +): Promise<T> { +  const lockKey = `${namespace}:${idempotencyKey}`; +  const previousTail = lockTails.get(lockKey) ?? Promise.resolve(); + +  let releaseCurrent!: () => void; +  const currentTail = new Promise<void>((resolve) => { +    releaseCurrent = resolve; +  }); +  const mergedTail = previousTail.then(() => currentTail); +  lockTails.set(lockKey, mergedTail); + +  await previousTail; +  try { +    return await task(); +  } finally { +    releaseCurrent(); +    if (lockTails.get(lockKey) === mergedTail) { +      lockTails.delete(lockKey); +    } +  } +}
diff --git a/src/infra/mapper/decision-card-mapper.ts b/src/infra/mapper/decision-card-mapper.ts new file mode 100644 index 0000000..70418a4 --- /dev/null +++ b/src/infra/mapper/decision-card-mapper.ts @@ -0,0 +1,50 @@ +import type { +  DecisionCardDto, +  DecisionCardInputDto, +  DecisionCardRequestDto, +} from "@/shared/contracts/decision-card"; +import { mapTopLevelKeysSnakeToCamel } from "@/infra/mapper/case-mapper"; +import type { DecisionCardDomainModel } from "@/domain/decision/decision-card-service"; + +function mapOptionsToDto(options: DecisionCardDomainModel["options"]): DecisionCardDto["options"] { +  return options.map((option) => ({ +    action: option.action, +    rationaleSummary: option.rationale_summary, +    confidenceScore: option.confidence_score, +    riskLevel: option.risk_level, +  })); +} + +export function mapDecisionCardRequest(body: unknown): Partial<DecisionCardRequestDto> { +  if (typeof body !== "object" || body === null) { +    return {}; +  } + +  const mapped = mapTopLevelKeysSnakeToCamel(body as Record<string, unknown>); +  const input = mapped.input; +  if (typeof input !== "object" || input === null) { +    return mapped as Partial<DecisionCardRequestDto>; +  } + +  const mappedInput = mapTopLevelKeysSnakeToCamel(input as Record<string, unknown>); +  return { +    ...mapped, +    input: mappedInput as Partial<DecisionCardInputDto>, +  } as Partial<DecisionCardRequestDto>; +} + +export function mapDecisionCardDomainToDto(model: DecisionCardDomainModel): DecisionCardDto { +  return { +    options: mapOptionsToDto(model.options), +    intentContext: { +      trustFreshnessHours: model.intent_context.trust_freshness_hours, +      trustConfidence: model.intent_context.trust_confidence, +    }, +    assetTransition: { +      currentState: model.asset_transition.current_state, +      lastTransitionAt: model.asset_transition.last_transition_at, +      version: model.asset_transition.version, +    }, +    fallbackApplied: model.fallback_applied, +  }; +}
diff --git a/src/shared/contracts/decision-card.ts b/src/shared/contracts/decision-card.ts new file mode 100644 index 0000000..de8715c --- /dev/null +++ b/src/shared/contracts/decision-card.ts @@ -0,0 +1,67 @@ +export const DECISION_ACTION_VALUES = ["buy", "sell", "hold", "alternative"] as const; +export const DECISION_RISK_LEVEL_VALUES = ["low", "medium", "high"] as const; +export const DECISION_TRUST_CONFIDENCE_VALUES = ["low", "medium", "high"] as const; +export const DECISION_ASSET_STATE_VALUES = ["owned", "held", "selling", "leased"] as const; +export const DECISION_TIME_PRESSURE_VALUES = ["low", "medium", "high"] as const; +export const DECISION_LIQUIDITY_NEED_VALUES = ["low", "medium", "high"] as const; + +export type DecisionAction = (typeof DECISION_ACTION_VALUES)[number]; +export type DecisionRiskLevel = (typeof DECISION_RISK_LEVEL_VALUES)[number]; +export type DecisionTrustConfidence = (typeof DECISION_TRUST_CONFIDENCE_VALUES)[number]; +export type DecisionAssetState = (typeof DECISION_ASSET_STATE_VALUES)[number]; +export type DecisionTimePressure = (typeof DECISION_TIME_PRESSURE_VALUES)[number]; +export type DecisionLiquidityNeed = (typeof DECISION_LIQUIDITY_NEED_VALUES)[number]; + +export type DecisionOptionDto = { +  action: DecisionAction; +  rationaleSummary: string; +  confidenceScore: number; +  riskLevel: DecisionRiskLevel; +}; + +export type DecisionIntentContextDto = { +  trustFreshnessHours: number; +  trustConfidence: DecisionTrustConfidence; +}; + +export type DecisionAssetTransitionDto = { +  currentState: DecisionAssetState; +  lastTransitionAt: string; +  version: number; +}; + +export type DecisionCardDto = { +  options: DecisionOptionDto[]; +  intentContext: DecisionIntentContextDto; +  assetTransition: DecisionAssetTransitionDto; +  fallbackApplied: boolean; +}; + +export type DecisionCardInputDto = { +  assetId: string; +  timePressure: DecisionTimePressure; +  liquidityNeed: DecisionLiquidityNeed; +  trustFreshnessHours?: number; +}; + +export type DecisionCardRequestDto = { +  input: DecisionCardInputDto; +}; + +export type DecisionCardResponseDto = { +  decisionCard: DecisionCardDto; +}; + +export type DecisionEventCanonical = "decision_card_generated" | "decision_card_error"; +export type DecisionEventName = "decision.card.generated.v1" | "decision.card.error.v1"; +export type DecisionEventAlias = "decision_generated" | "decision_error"; + +export const DECISION_EVENT_NAME_TO_CANONICAL: Record<DecisionEventName, DecisionEventCanonical> = { +  "decision.card.generated.v1": "decision_card_generated", +  "decision.card.error.v1": "decision_card_error", +}; + +export const DECISION_EVENT_ALIAS_TO_CANONICAL: Record<DecisionEventAlias, DecisionEventCanonical> = { +  decision_generated: "decision_card_generated", +  decision_error: "decision_card_error", +};
diff --git a/tests/e2e/decision-card-api.contract.spec.ts b/tests/e2e/decision-card-api.contract.spec.ts new file mode 100644 index 0000000..bed40a5 --- /dev/null +++ b/tests/e2e/decision-card-api.contract.spec.ts @@ -0,0 +1,90 @@ +import { expect, test } from "@playwright/test"; + +const baseInput = { +  assetId: `asset_decision_${crypto.randomUUID()}`, +  timePressure: "medium", +  liquidityNeed: "low", +}; + +test.describe("판단 카드 API 계약", () => { +  test("정상 응답: 4개 선택지와 intent/transition 문맥을 반환한다", async ({ request }) => { +    const response = await request.post("/api/decision-cards", { +      data: { +        input: baseInput, +      }, +    }); + +    expect(response.status()).toBe(200); +    const payload = await response.json(); + +    expect(payload.data.decisionCard.options).toHaveLength(4); +    for (const option of payload.data.decisionCard.options as Array<{ +      confidenceScore: number; +      riskLevel: string; +    }>) { +      expect(option.confidenceScore).toBeGreaterThanOrEqual(0); +      expect(option.confidenceScore).toBeLessThanOrEqual(1); +      expect(["low", "medium", "high"]).toContain(option.riskLevel); +    } + +    expect(typeof payload.data.decisionCard.intentContext.trustFreshnessHours).toBe("number"); +    expect(["low", "medium", "high"]).toContain(payload.data.decisionCard.intentContext.trustConfidence); +    expect(["owned", "held", "selling", "leased"]).toContain( +      payload.data.decisionCard.assetTransition.currentState, +    ); +    expect(Number.isNaN(Date.parse(payload.data.decisionCard.assetTransition.lastTransitionAt))).toBeFalsy(); +    expect(typeof payload.data.decisionCard.assetTransition.version).toBe("number"); +  }); + +  test("유효성 실패: 400 오류 규약과 recoveryGuide를 반환한다", async ({ request }) => { +    const response = await request.post("/api/decision-cards", { +      data: { +        input: { +          assetId: "", +          timePressure: "wrong", +        }, +      }, +    }); + +    expect(response.status()).toBe(400); +    const payload = await response.json(); +    expect(payload.error.code).toBe("INVALID_INPUT"); +    expect(typeof payload.error.message).toBe("string"); +    expect(typeof payload.error.requestId).toBe("string"); +    expect(typeof payload.error.details.recoveryGuide).toBe("string"); +  }); + +  test("fallback: trustFreshnessHours 초과 시 fallbackApplied=true와 error 이벤트를 남긴다", async ({ +    request, +  }) => { +    const staleHours = 169; +    const response = await request.post("/api/decision-cards", { +      data: { +        input: { +          ...baseInput, +          assetId: `asset_decision_fallback_${crypto.randomUUID()}`, +          trustFreshnessHours: staleHours, +        }, +      }, +    }); + +    expect(response.status()).toBe(200); +    const payload = await response.json(); +    expect(payload.data.decisionCard.fallbackApplied).toBeTruthy(); + +    const events = payload.meta.events as Array<{ +      eventId: string; +      occurredAt: string; +      traceId: string; +      schemaVersion: number; +      canonical: string; +    }>; +    expect(Array.isArray(events)).toBeTruthy(); +    const errorEvent = events.find((event) => event.canonical === "decision_card_error"); +    expect(errorEvent).toBeTruthy(); +    expect(errorEvent?.eventId).toMatch(/^evt_/); +    expect(Number.isNaN(Date.parse(String(errorEvent?.occurredAt)))).toBeFalsy(); +    expect(typeof errorEvent?.traceId).toBe("string"); +    expect(errorEvent?.schemaVersion).toBe(1); +  }); +});

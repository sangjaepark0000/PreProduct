@@ -0,0 +1,27 @@
+# PreProduct Workspace
+
+## BMad Git 자동 관리
+
+개인 프로젝트에서 BMad 진행 중 Git 히스토리를 일관되게 남기기 위한 로컬 자동화 스크립트입니다.
+
+### 범위
+- `feat/<slug>` 브랜치 자동 생성 또는 전환
+- 단계별 규칙 커밋 메시지 생성: `bmad(<phase>): <slug> [<tag>]`
+- 변경사항이 없으면 커밋 생략
+
+### 안전 원칙
+- 자동 push 없음
+- 히스토리 재작성 없음
+- 파괴적 명령(`reset --hard`, `clean -fd`) 없음
+
+### 실행 예시
+```powershell
+powershell -ExecutionPolicy Bypass -File .\scripts\bmad-git.ps1 init -RepositoryPath .\preproduct -Slug "bmad-git-automation" -CreateBaselineCommit
+powershell -ExecutionPolicy Bypass -File .\scripts\bmad-git.ps1 commit -RepositoryPath .\preproduct -Slug "bmad-git-automation" -Phase "step-03" -Tag "auto"
+powershell -ExecutionPolicy Bypass -File .\scripts\bmad-git.ps1 self-check -RepositoryPath .\preproduct
+```
+
+### 권장 루틴
+1. BMad 작업 시작 시 `init`으로 기준선과 작업 브랜치를 준비한다.
+2. 단계 종료마다 `commit`을 호출해 변경 이유를 분리 기록한다.
+3. 원격 반영은 필요할 때만 수동으로 수행한다.
diff --git a/scripts/bmad-git.ps1 b/scripts/bmad-git.ps1
new file mode 100644
index 0000000..e35030d
--- /dev/null
+++ b/scripts/bmad-git.ps1
@@ -0,0 +1,175 @@
+[CmdletBinding()]
+param(
+  [Parameter(Position = 0)]
+  [ValidateSet('init', 'commit', 'self-check')]
+  [string]$Mode,
+
+  [string]$Slug,
+  [string]$Phase,
+  [string]$Tag = 'auto',
+  [string]$RepositoryPath,
+  [string]$BranchPrefix = 'feat',
+  [switch]$CreateBaselineCommit,
+  [switch]$DryRun
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail([string]$Message) {
+  Write-Output "ERROR: $Message"
+  exit 1
+}
+
+function Test-ValidSlug([string]$Value) {
+  return $Value -match '^[a-z0-9]+(?:-[a-z0-9]+)*$'
+}
+
+function Test-ValidPhase([string]$Value) {
+  return $Value -match '^[a-z0-9]+(?:-[a-z0-9]+)*$'
+}
+
+function Find-GitRepo([string]$ExplicitPath) {
+  $candidates = @()
+  if ($ExplicitPath) {
+    $resolved = (Resolve-Path -Path $ExplicitPath).Path
+    $candidates += $resolved
+  } else {
+    $candidates += (Get-Location).Path
+    $candidates += (Resolve-Path -Path (Join-Path $PSScriptRoot '..')).Path
+
+    $parent = (Resolve-Path -Path (Join-Path $PSScriptRoot '..')).Path
+    $children = Get-ChildItem -Path $parent -Directory -ErrorAction SilentlyContinue
+    foreach ($child in $children) {
+      if (Test-Path (Join-Path $child.FullName '.git')) {
+        $candidates += $child.FullName
+      }
+    }
+  }
+
+  $unique = $candidates | Select-Object -Unique
+  foreach ($candidate in $unique) {
+    $inside = & git -C $candidate rev-parse --is-inside-work-tree 2>$null
+    if ($LASTEXITCODE -eq 0 -and $inside -eq 'true') {
+      return $candidate
+    }
+  }
+
+  return $null
+}
+
+function Get-DirtyState([string]$Repo) {
+  $status = & git -C $Repo status --porcelain
+  return -not [string]::IsNullOrWhiteSpace(($status -join "`n"))
+}
+
+function Ensure-CheckedOutBranch([string]$Repo, [string]$BranchName) {
+  & git -C $Repo show-ref --verify --quiet "refs/heads/$BranchName"
+  if ($LASTEXITCODE -eq 0) {
+    if ($DryRun) {
+      Write-Output "[dry-run] git -C $Repo checkout $BranchName"
+      return
+    }
+    & git -C $Repo checkout $BranchName | Out-Null
+    if ($LASTEXITCODE -ne 0) { Fail "브랜치 전환 실패: $BranchName" }
+    Write-Output "브랜치 전환: $BranchName"
+    return
+  }
+
+  if ($DryRun) {
+    Write-Output "[dry-run] git -C $Repo checkout -b $BranchName"
+    return
+  }
+  & git -C $Repo checkout -b $BranchName | Out-Null
+  if ($LASTEXITCODE -ne 0) { Fail "브랜치 생성 실패: $BranchName" }
+  Write-Output "브랜치 생성: $BranchName"
+}
+
+function New-BmadCommit([string]$Repo, [string]$Message) {
+  $isDirty = Get-DirtyState -Repo $Repo
+  if (-not $isDirty) {
+    Write-Output '변경사항 없음: 커밋 생략'
+    return
+  }
+
+  if ($DryRun) {
+    Write-Output "[dry-run] git -C $Repo add -A"
+    Write-Output "[dry-run] git -C $Repo commit -m `"$Message`""
+    return
+  }
+
+  & git -C $Repo add -A
+  if ($LASTEXITCODE -ne 0) { Fail 'git add 실패' }
+
+  & git -C $Repo commit -m $Message | Out-Null
+  if ($LASTEXITCODE -ne 0) { Fail 'git commit 실패' }
+
+  Write-Output "커밋 완료: $Message"
+}
+
+function Run-InitMode {
+  if (-not $Slug) { Fail 'init 모드는 -Slug가 필요합니다.' }
+  if (-not (Test-ValidSlug $Slug)) { Fail '유효하지 않은 slug 형식입니다. 예: bmad-git-automation' }
+
+  $repo = Find-GitRepo -ExplicitPath $RepositoryPath
+  if (-not $repo) { Fail 'Git 저장소를 찾지 못했습니다. -RepositoryPath를 지정하세요.' }
+
+  $branchName = "$BranchPrefix/$Slug"
+
+  if ($CreateBaselineCommit) {
+    New-BmadCommit -Repo $repo -Message "bmad(init): $Slug [baseline]"
+  }
+
+  Ensure-CheckedOutBranch -Repo $repo -BranchName $branchName
+  Write-Output "repo=$repo"
+}
+
+function Run-CommitMode {
+  if (-not $Slug) { Fail 'commit 모드는 -Slug가 필요합니다.' }
+  if (-not (Test-ValidSlug $Slug)) { Fail '유효하지 않은 slug 형식입니다. 예: bmad-git-automation' }
+  if (-not $Phase) { Fail 'commit 모드는 -Phase가 필요합니다.' }
+  if (-not (Test-ValidPhase $Phase)) { Fail '유효하지 않은 phase 형식입니다. 예: step-03' }
+
+  $repo = Find-GitRepo -ExplicitPath $RepositoryPath
+  if (-not $repo) { Fail 'Git 저장소를 찾지 못했습니다. -RepositoryPath를 지정하세요.' }
+
+  $message = "bmad($Phase): $Slug [$Tag]"
+  New-BmadCommit -Repo $repo -Message $message
+  Write-Output "repo=$repo"
+}
+
+function Run-SelfCheckMode {
+  $repo = Find-GitRepo -ExplicitPath $RepositoryPath
+  if (-not $repo) { Fail 'Git 저장소를 찾지 못했습니다. -RepositoryPath를 지정하세요.' }
+
+  $checks = @(
+    @{ Name = 'slug-valid'; Pass = (Test-ValidSlug 'bmad-git-automation') },
+    @{ Name = 'slug-invalid'; Pass = (-not (Test-ValidSlug 'bad_slug')) },
+    @{ Name = 'phase-valid'; Pass = (Test-ValidPhase 'step-03') },
+    @{ Name = 'phase-invalid'; Pass = (-not (Test-ValidPhase 'step_03')) },
+    @{ Name = 'repo-detected'; Pass = $true }
+  )
+
+  $failed = @($checks | Where-Object { -not $_.Pass })
+  foreach ($check in $checks) {
+    $state = if ($check.Pass) { 'PASS' } else { 'FAIL' }
+    Write-Output ("[{0}] {1}" -f $state, $check.Name)
+  }
+
+  if (@($failed).Count -gt 0) {
+    Fail 'self-check 실패'
+  }
+
+  Write-Output "self-check 완료: repo=$repo"
+}
+
+if (-not $Mode) {
+  Fail 'Mode를 지정하세요: init | commit | self-check'
+}
+
+switch ($Mode) {
+  'init' { Run-InitMode }
+  'commit' { Run-CommitMode }
+  'self-check' { Run-SelfCheckMode }
+  default { Fail '지원하지 않는 모드입니다.' }
+}

@@ -0,0 +1,18 @@
+export type AnyRecord = Record<string, unknown>;
+
+export function snakeToCamelCase(input: string): string {
+  return input.replace(/_([a-z])/g, (_, char: string) => char.toUpperCase());
+}
+
+export function mapTopLevelKeysSnakeToCamel<T extends AnyRecord>(source: T): AnyRecord {
+  return Object.entries(source).reduce<AnyRecord>((acc, [key, value]) => {
+    const mappedKey = snakeToCamelCase(key);
+    if (Object.prototype.hasOwnProperty.call(acc, mappedKey)) {
+      throw new Error(`Key collision while mapping snake_case to camelCase: ${key} -> ${mappedKey}`);
+    }
+    acc[mappedKey] = value;
+    return acc;
+  }, {});
+}
+
+export const mapKeysSnakeToCamel = mapTopLevelKeysSnakeToCamel;
